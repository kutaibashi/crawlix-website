---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { ChevronRight } from '@lucide/astro';

export const prerender = true;
---

<BaseLayout
  title="About the Crawlix Crawler Bot"
  description="Information about the Crawlix web crawler, how it works, and how to control its access to your site."
>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <Header slot="header" />

  <div style="background: #040c1e;">

    <!-- Hero -->
    <section class="relative pt-32 pb-12 overflow-hidden" style="background: radial-gradient(ellipse 60% 50% at 50% 40%, #0c2340, #040c1e);">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-slate-600 mb-8">
          <a href="/" class="hover:text-slate-400 transition-colors">Home</a>
          <ChevronRight class="h-3 w-3" />
          <span class="text-slate-400">Bot</span>
        </nav>

        <div class="max-w-2xl">
          <h1 class="text-3xl font-bold text-white sm:text-4xl lg:text-5xl leading-[1.15]">
            About the Crawlix Crawler
          </h1>
          <p class="mt-4 text-xl text-slate-300">
            Crawlix is a desktop SEO crawler. When a user runs a crawl, the Crawlix bot visits pages on their behalf to audit technical SEO, content quality, and performance.
          </p>
        </div>
      </div>
    </section>

    <!-- User Agent -->
    <section class="py-14 border-t border-slate-800/30" id="main-content">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white mb-4">User Agent</h2>
        <p class="text-slate-300 mb-4">The Crawlix crawler identifies itself with the following user agent string:</p>
        <code class="block text-sm text-cyan-400 bg-slate-900/50 rounded-lg p-4 break-all border border-slate-800/30">
          Crawlix/2.0 (compatible; SEO Crawler; +https://crawlix.app/bot)
        </code>
      </div>
    </section>

    <!-- How it works -->
    <section class="py-14 border-t border-slate-800/30">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white mb-4">How it works</h2>
        <p class="text-slate-300 mb-6">
          Crawlix is not a search engine and does not index content. It is a desktop application that runs on the user's machine. When someone audits a website with Crawlix, the crawler:
        </p>
        <ul class="space-y-3 text-slate-300">
          <li class="flex gap-3">
            <span class="w-0.5 shrink-0 rounded-full bg-[#22d3ee]/30 mt-1" style="min-height: 100%;"></span>
            <span>Fetches pages starting from a URL the user provides</span>
          </li>
          <li class="flex gap-3">
            <span class="w-0.5 shrink-0 rounded-full bg-[#22d3ee]/30 mt-1" style="min-height: 100%;"></span>
            <span>Follows internal links to discover the site structure</span>
          </li>
          <li class="flex gap-3">
            <span class="w-0.5 shrink-0 rounded-full bg-[#22d3ee]/30 mt-1" style="min-height: 100%;"></span>
            <span>Analyzes each page for SEO issues, accessibility, and performance</span>
          </li>
          <li class="flex gap-3">
            <span class="w-0.5 shrink-0 rounded-full bg-[#22d3ee]/30 mt-1" style="min-height: 100%;"></span>
            <span>Stores all data locally on the user's machine — nothing is uploaded to any server</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- Controlling access -->
    <section class="py-14 border-t border-slate-800/30">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white mb-4">Controlling access</h2>
        <p class="text-slate-300 mb-6">
          Crawlix respects <code class="text-cyan-400">robots.txt</code> by default. To block the Crawlix crawler from accessing your site, add the following to your <code class="text-cyan-400">robots.txt</code> file:
        </p>
        <pre class="text-sm text-slate-300 bg-slate-900/50 rounded-lg p-4 border border-slate-800/30 overflow-x-auto"><code>User-agent: Crawlix
Disallow: /</code></pre>
        <p class="text-slate-400 text-sm mt-4">
          Note: Crawlix users can choose to ignore robots.txt in their crawl settings. Since Crawlix is a site auditing tool, site owners often run it on their own sites with robots.txt compliance disabled to get a complete audit.
        </p>
      </div>
    </section>

    <!-- Crawl behavior -->
    <section class="py-14 border-t border-slate-800/30">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white mb-4">Crawl behavior</h2>

        <table class="text-sm max-w-lg">
          <tbody>
            <tr class="border-b border-slate-800/30">
              <td class="py-2.5 pr-8 text-slate-300">Default crawl delay</td>
              <td class="py-2.5 font-mono text-white">350ms</td>
            </tr>
            <tr class="border-b border-slate-800/30">
              <td class="py-2.5 pr-8 text-slate-300">Default concurrent workers</td>
              <td class="py-2.5 font-mono text-white">5</td>
            </tr>
            <tr class="border-b border-slate-800/30">
              <td class="py-2.5 pr-8 text-slate-300">Respects robots.txt</td>
              <td class="py-2.5 font-mono text-white">Yes (by default)</td>
            </tr>
            <tr class="border-b border-slate-800/30">
              <td class="py-2.5 pr-8 text-slate-300">Respects crawl-delay</td>
              <td class="py-2.5 font-mono text-white">Yes</td>
            </tr>
            <tr class="border-b border-slate-800/30">
              <td class="py-2.5 pr-8 text-slate-300">Follows external links</td>
              <td class="py-2.5 font-mono text-white">No (by default)</td>
            </tr>
            <tr>
              <td class="py-2.5 pr-8 text-slate-300">Stores data externally</td>
              <td class="py-2.5 font-mono text-white">No — local only</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Contact -->
    <section class="py-14 border-t border-slate-800/30">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white mb-4">Contact</h2>
        <p class="text-slate-300">
          If you have questions or concerns about the Crawlix crawler, contact us at
          <a href="mailto:support@crawlix.app" class="text-cyan-400 hover:text-white transition-colors">support@crawlix.app</a>.
        </p>
      </div>
    </section>

  </div>

  <Footer slot="footer" />
</BaseLayout>
