---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
import StructuredData from '../components/seo/StructuredData.astro';
import { Check, X, Download, ArrowRight, Shield, CreditCard, RefreshCw, Sparkles } from '@lucide/astro';
import { getPricingTiers, getFAQs, getTotalSeoChecks } from '../lib/keystatic';
import { featureComparison, featureCategories, lemonSqueezyConfig } from '../data/pricing';

export const prerender = true;

const pricingTiersData = await getPricingTiers();
const pricingFaqsData = await getFAQs('pricing');
const totalSeoChecks = await getTotalSeoChecks();

const pricingTiers = pricingTiersData.sort((a, b) => a.priceAnnual - b.priceAnnual);

const licensingFaqs = await getFAQs('licensing');
const pricingFaqs = [...pricingFaqsData, ...licensingFaqs].sort((a, b) => a.order - b.order);

const variantIds = {
  professional: {
    monthly: lemonSqueezyConfig.variants.proMonthly,
    yearly: lemonSqueezyConfig.variants.proYearly,
    perpetual: lemonSqueezyConfig.variants.proPerpetual,
  },
  enterprise: {
    monthly: lemonSqueezyConfig.variants.agencyMonthly,
    yearly: lemonSqueezyConfig.variants.agencyYearly,
    perpetual: lemonSqueezyConfig.variants.agencyPerpetual,
  },
};

const monthlyPrices = {
  professional: 15,
  enterprise: 45,
};

// Node-graph background — deterministic via seeded PRNG
function seededRand(seed: number) {
  let s = seed;
  return () => {
    s = (s * 1664525 + 1013904223) & 0xffffffff;
    return (s >>> 0) / 0xffffffff;
  };
}

const rand = seededRand(77);
const COLS = 10;
const ROWS = 6;
const W = 100;
const H = 100;
const CONNECT_DIST = 15;

interface GraphNode { x: number; y: number; opacity: number; delay: number; }
const nodes: GraphNode[] = [];

for (let row = 0; row < ROWS; row++) {
  for (let col = 0; col < COLS; col++) {
    const baseX = (col / (COLS - 1)) * W;
    const baseY = (row / (ROWS - 1)) * H;
    const jx = (rand() - 0.5) * 10;
    const jy = (rand() - 0.5) * 10;
    nodes.push({
      x: Math.max(0, Math.min(W, baseX + jx)),
      y: Math.max(0, Math.min(H, baseY + jy)),
      opacity: 0.08 + rand() * 0.2,
      delay: rand() * 4,
    });
  }
}

interface GraphEdge { x1: number; y1: number; x2: number; y2: number; opacity: number; delay: number; }
const edges: GraphEdge[] = [];

for (let i = 0; i < nodes.length; i++) {
  for (let j = i + 1; j < nodes.length; j++) {
    const dx = nodes[i].x - nodes[j].x;
    const dy = nodes[i].y - nodes[j].y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < CONNECT_DIST && rand() > 0.35) {
      edges.push({
        x1: nodes[i].x, y1: nodes[i].y,
        x2: nodes[j].x, y2: nodes[j].y,
        opacity: 0.02 + rand() * 0.06,
        delay: rand() * 5,
      });
    }
  }
}

// Competitor data for value comparison
const competitors = [
  { name: 'Screaming Frog', price: 259, unit: '/yr', pages: 'Unlimited', perpetual: false, type: 'Desktop' },
  { name: 'Sitebulb Pro', price: 420, unit: '/yr', pages: '500K', perpetual: false, type: 'Desktop' },
  { name: 'Ahrefs Lite', price: 1548, unit: '/yr', pages: '100K/mo', perpetual: false, type: 'Cloud' },
  { name: 'SEMrush Pro', price: 1399, unit: '/yr', pages: '100K/mo', perpetual: false, type: 'Cloud' },
];

const maxCompetitorPrice = Math.max(...competitors.map(c => c.price));
---

<BaseLayout
  title="Pricing"
  description={`Simple, honest pricing for Crawlix. Free tier with full ${totalSeoChecks}+ check analysis power. Pro from $149/year. Perpetual license option available.`}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Pricing', url: '/pricing' },
  ]}
>
  {pricingFaqs.length > 0 && (
    <StructuredData
      type="faq"
      data={{ faqs: pricingFaqs }}
    />
  )}

  <a href="#main-content" class="skip-link">Skip to main content</a>
  <Header slot="header" />

  <!-- ============================================================
       HERO — Node-graph background, billing toggle
       ============================================================ -->
  <section class="relative pt-32 pb-20 overflow-hidden" style="background:radial-gradient(ellipse 60% 50% at 50% 40%, #0c2340, #040c1e);">
    <!-- Node-graph network background -->
    <svg
      class="absolute inset-0 w-full h-full pointer-events-none"
      viewBox="0 0 100 100"
      preserveAspectRatio="xMidYMid slice"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      {edges.map((e) => (
        <line
          class="pricing-edge"
          x1={e.x1} y1={e.y1} x2={e.x2} y2={e.y2}
          stroke="#22d3ee" stroke-width="0.12"
          style={`--base-opacity:${e.opacity}; opacity:${e.opacity}; animation-delay:${e.delay.toFixed(2)}s;`}
        />
      ))}
      {nodes.map((n) => (
        <circle
          class="pricing-node"
          cx={n.x} cy={n.y} r="0.45"
          fill="#22d3ee"
          style={`--base-opacity:${n.opacity}; opacity:${n.opacity}; animation-delay:${n.delay.toFixed(2)}s;`}
        />
      ))}
      <defs>
        <radialGradient id="pricing-center-fade" cx="50%" cy="50%" r="55%">
          <stop offset="0%" stop-color="#040c1e" stop-opacity="0.72" />
          <stop offset="60%" stop-color="#040c1e" stop-opacity="0.25" />
          <stop offset="100%" stop-color="#040c1e" stop-opacity="0" />
        </radialGradient>
      </defs>
      <rect x="0" y="0" width="100" height="100" fill="url(#pricing-center-fade)" />
    </svg>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <!-- Stats badge -->
      <div class="inline-flex items-center gap-2 rounded-full border border-[#22d3ee]/15 bg-[#22d3ee]/5 px-4 py-1.5 text-xs text-[#22d3ee]/90 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-[#22d3ee] shadow-[0_0_8px_rgba(34,211,238,0.4)]"></span>
        <span class="font-semibold">Perpetual License Available</span>
        <span class="text-slate-600">|</span>
        <span class="text-slate-500">Pay once, own forever</span>
      </div>

      <h1 class="text-3xl font-bold tracking-tight sm:text-5xl lg:text-6xl leading-[1.1]">
        <span class="text-white">One Price.</span><br />
        <span class="gradient-text-cyan font-extrabold text-4xl sm:text-5xl lg:text-[4.25rem]">Every Check Included.</span>
      </h1>
      <p class="mt-6 text-base sm:text-lg text-slate-400 max-w-xl mx-auto leading-relaxed">
        All {totalSeoChecks}+ SEO checks are free on every tier. Upgrade for more pages, exports, and integrations.
      </p>

      <!-- Billing Toggle -->
      <div class="mt-10 inline-flex items-center gap-1 p-1.5 rounded-full bg-[#091a3d]/80 border border-slate-800/60 backdrop-blur-sm">
        <button
          type="button"
          class="billing-btn billing-inactive px-5 py-2.5 rounded-full text-sm font-medium transition-all"
          data-billing="monthly"
        >
          Monthly
        </button>
        <button
          type="button"
          class="billing-btn billing-active px-5 py-2.5 rounded-full text-sm font-medium transition-all"
          data-billing="annual"
        >
          Annual
          <span class="ml-1.5 inline-flex items-center rounded-full bg-emerald-500/10 px-2 py-0.5 text-xs text-emerald-400">
            Save 17%
          </span>
        </button>
        <button
          type="button"
          class="billing-btn billing-inactive px-5 py-2.5 rounded-full text-sm font-medium transition-all"
          data-billing="perpetual"
        >
          Perpetual
        </button>
      </div>
    </div>

    <!-- Bottom gradient fade -->
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-[#091a3d] to-transparent z-10"></div>
  </section>

  <!-- ============================================================
       PRICING CARDS
       ============================================================ -->
  <section class="pb-24 pt-4" style="background:#091a3d;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-3">
        {pricingTiers.map((tier) => (
          <div
            class={`relative rounded-2xl p-8 transition-all duration-300 hover-lift ${
              tier.highlighted
                ? 'pricing-card-pro border border-[#22d3ee]/40 bg-[#22d3ee]/[0.04] shadow-xl shadow-[#22d3ee]/10'
                : tier.id === 'starter'
                  ? 'pricing-card-free glass-card'
                  : 'pricing-card-agency glass-card'
            }`}
          >
            {/* Badge */}
            {tier.badge && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-[#22d3ee] px-4 py-1.5 text-xs font-semibold text-slate-900 shadow-lg shadow-[#22d3ee]/30">
                  <Sparkles class="h-3.5 w-3.5" />
                  {tier.badge}
                </span>
              </div>
            )}

            <div>
              <h3 class="text-xl font-semibold text-white">{tier.name}</h3>
              <p class="mt-1 text-sm text-slate-500">{tier.description}</p>

              {/* Price */}
              <div class="mt-6 h-20 relative" data-tier={tier.id}>
                {tier.priceAnnual === 0 ? (
                  <div>
                    <span class="text-5xl font-bold text-white">$0</span>
                    <span class="text-slate-500 ml-2">forever</span>
                  </div>
                ) : (
                  <>
                    <div class="price-monthly hidden">
                      <span class="text-5xl font-bold text-white">${monthlyPrices[tier.id as keyof typeof monthlyPrices] || 0}</span>
                      <span class="text-slate-500 ml-2">/month</span>
                      <div class="mt-1 text-sm text-slate-600">
                        Billed monthly, cancel anytime
                      </div>
                    </div>
                    <div class="price-annual">
                      <span class="text-5xl font-bold text-white">${tier.priceAnnual}</span>
                      <span class="text-slate-500 ml-2">/year</span>
                      <div class="mt-1 text-sm text-emerald-400/80">
                        Save ${(monthlyPrices[tier.id as keyof typeof monthlyPrices] || 0) * 12 - tier.priceAnnual}/year vs monthly
                      </div>
                    </div>
                    <div class="price-perpetual hidden">
                      <span class="text-5xl font-bold text-white">${tier.pricePerpetual}</span>
                      <span class="text-slate-500 ml-2">one-time</span>
                      <div class="mt-1 text-sm text-emerald-400/80">
                        Own forever + 1 year of updates
                      </div>
                    </div>
                  </>
                )}
              </div>

              {/* Key Limits */}
              <div class="mt-6 grid grid-cols-2 gap-3 p-4 rounded-xl bg-slate-900/40 border border-slate-800/50">
                <div class="text-center">
                  <div class="text-lg font-bold text-white">{tier.limits.pages}</div>
                  <div class="text-xs text-slate-600">pages/crawl</div>
                </div>
                <div class="text-center">
                  <div class="text-lg font-bold text-white">{tier.limits.projects}</div>
                  <div class="text-xs text-slate-600">projects</div>
                </div>
              </div>
            </div>

            {/* Features */}
            <ul class="mt-8 space-y-3">
              {tier.features.map((feature, idx) => (
                <li class="flex items-start gap-3">
                  {idx === 0 && feature.includes('Everything') ? (
                    <>
                      <ArrowRight class="h-5 w-5 shrink-0 text-slate-600 mt-0.5" />
                      <span class="text-sm text-slate-500 font-medium">{feature}</span>
                    </>
                  ) : (
                    <>
                      <div class={`flex h-5 w-5 shrink-0 items-center justify-center rounded-full ${
                        tier.id === 'starter' ? 'bg-emerald-500/15' :
                        tier.highlighted ? 'bg-[#22d3ee]/15' :
                        'bg-[#a78bfa]/15'
                      }`}>
                        <Check class={`h-3 w-3 ${
                          tier.id === 'starter' ? 'text-emerald-400' :
                          tier.highlighted ? 'text-[#22d3ee]' :
                          'text-[#a78bfa]'
                        }`} />
                      </div>
                      <span class="text-sm text-slate-300">{feature}</span>
                    </>
                  )}
                </li>
              ))}
            </ul>

            {/* CTA */}
            <div class="mt-8">
              {tier.priceAnnual === 0 ? (
                <a
                  href="/download"
                  class="w-full inline-flex items-center justify-center gap-2 rounded-xl border border-emerald-500/30 bg-emerald-500/[0.06] px-6 py-3 font-semibold text-white hover:bg-emerald-500/10 hover:border-emerald-500/50 transition-all"
                >
                  <Download class="h-5 w-5" />
                  {tier.cta}
                </a>
              ) : (
                <a
                  href="#"
                  class={`checkout-btn w-full inline-flex items-center justify-center gap-2 rounded-xl px-6 py-3 font-semibold transition-all duration-200 ${
                    tier.highlighted
                      ? 'bg-[#22d3ee] text-slate-900 hover:bg-[#67e8f9] shadow-lg shadow-[#22d3ee]/20 hover:shadow-[#22d3ee]/30'
                      : 'border border-[#a78bfa]/30 bg-[#a78bfa]/[0.06] text-white hover:bg-[#a78bfa]/10 hover:border-[#a78bfa]/50'
                  }`}
                  data-tier={tier.id}
                  data-variant-monthly={variantIds[tier.id as keyof typeof variantIds]?.monthly || ''}
                  data-variant-yearly={variantIds[tier.id as keyof typeof variantIds]?.yearly || ''}
                  data-variant-perpetual={variantIds[tier.id as keyof typeof variantIds]?.perpetual || ''}
                >
                  {tier.cta}
                </a>
              )}
            </div>
          </div>
        ))}
      </div>

      {/* Trust badges */}
      <div class="mt-14 flex flex-wrap items-center justify-center gap-8 text-sm text-slate-500">
        <div class="flex items-center gap-2">
          <Shield class="h-4 w-4 text-emerald-500/70" />
          <span>14-day money-back guarantee</span>
        </div>
        <div class="flex items-center gap-2">
          <CreditCard class="h-4 w-4 text-emerald-500/70" />
          <span>Secure payment via Lemon Squeezy</span>
        </div>
        <div class="flex items-center gap-2">
          <RefreshCw class="h-4 w-4 text-emerald-500/70" />
          <span>Cancel anytime</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       COMPETITOR VALUE COMPARISON
       ============================================================ -->
  <section class="py-24 sm:py-28 relative overflow-hidden" style="background:#040c1e;">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 relative z-10">
      <!-- Section header — left-aligned with cyan bar -->
      <div class="section-header-bar mb-14 max-w-xl animate-on-scroll">
        <span class="text-sm font-semibold text-[#22d3ee] uppercase tracking-widest">Value</span>
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl mt-3">
          More checks, lower price
        </h2>
        <p class="text-slate-400 text-base mt-3">
          Crawlix Pro at $149/year undercuts every major desktop SEO crawler — and none of them offer a perpetual license.
        </p>
      </div>

      <div class="rounded-2xl border border-slate-800/60 glass-card p-6 sm:p-8">
        <div class="space-y-4">
          {/* Crawlix row — highlighted */}
          <div class="flex items-center gap-4 p-3 rounded-xl bg-[#22d3ee]/[0.04] border border-[#22d3ee]/15">
            <div class="w-28 sm:w-36 shrink-0">
              <div class="text-sm font-semibold text-white">Crawlix Pro</div>
              <div class="flex items-center gap-1.5 mt-0.5">
                <span class="text-xs font-bold text-[#22d3ee]">$149/yr</span>
                <span class="text-[10px] font-semibold text-emerald-400 bg-emerald-500/10 px-1.5 py-0.5 rounded">✓ Buy once</span>
              </div>
            </div>
            <div class="flex-1 h-6 bg-slate-900/40 rounded overflow-hidden">
              <div
                class="h-full rounded"
                style={`width: ${(149 / maxCompetitorPrice * 100).toFixed(1)}%; background: linear-gradient(90deg, #22d3ee, #67e8f9);`}
              ></div>
            </div>
          </div>

          {/* Competitor rows */}
          {competitors.map((c) => (
            <div class="flex items-center gap-4 p-3">
              <div class="w-28 sm:w-36 shrink-0">
                <div class="text-sm text-slate-400">{c.name}</div>
                <div class="text-xs text-slate-600 mt-0.5">${c.price.toLocaleString()}/yr · {c.type}</div>
              </div>
              <div class="flex-1 h-5 bg-slate-900/40 rounded overflow-hidden">
                <div
                  class="h-full rounded bg-white/[0.08]"
                  style={`width: ${(c.price / maxCompetitorPrice * 100).toFixed(1)}%;`}
                ></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <p class="mt-4 text-xs text-slate-600 text-center">
        Prices from public pricing pages as of early 2026. Cloud tools bundle site audit with broader suites.
      </p>
    </div>
  </section>

  <!-- ============================================================
       FEATURE COMPARISON TABLE
       ============================================================ -->
  <section class="py-24 sm:py-28 relative overflow-hidden" style="background:#091a3d;" id="compare">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 relative z-10">
      <!-- Section header — left-aligned with cyan bar -->
      <div class="section-header-bar mb-14 max-w-xl animate-on-scroll">
        <span class="text-sm font-semibold text-[#22d3ee] uppercase tracking-widest">Compare Plans</span>
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl mt-3">
          Full feature comparison
        </h2>
        <p class="text-slate-400 text-base mt-3">
          All {totalSeoChecks}+ SEO checks included on every tier. Upgrade for more pages, exports, and integrations.
        </p>
      </div>

      <div class="overflow-x-auto rounded-2xl border border-slate-800/60 glass-card">
        <table class="w-full">
          <thead>
            <tr class="border-b border-slate-800/60">
              <th class="py-5 px-6 text-left text-sm font-semibold text-white sticky left-0 bg-[#091a3d]">Feature</th>
              <th class="py-5 px-6 text-center text-sm font-semibold text-slate-400 min-w-[120px]">Free</th>
              <th class="py-5 px-6 text-center text-sm font-semibold text-[#22d3ee] min-w-[120px] bg-[#22d3ee]/[0.03]">Pro</th>
              <th class="py-5 px-6 text-center text-sm font-semibold text-slate-400 min-w-[120px]">Agency</th>
            </tr>
          </thead>
          <tbody>
            {featureCategories.map((category) => {
              const categoryFeatures = featureComparison.filter(f => f.category === category);
              return (
                <>
                  <tr class="border-b border-slate-800/30 bg-slate-900/30">
                    <td colspan="4" class="py-3 px-6 text-xs font-semibold text-[#22d3ee]/70 uppercase tracking-wider">
                      {category}
                    </td>
                  </tr>
                  {categoryFeatures.map((row, rowIdx) => (
                    <tr class={`border-b border-slate-800/20 ${rowIdx % 2 === 0 ? '' : 'bg-slate-900/15'} hover:bg-slate-800/20 transition-colors`}>
                      <td class="py-4 px-6 text-sm text-slate-300 sticky left-0 bg-inherit">{row.feature}</td>
                      <td class="py-4 px-6 text-center">
                        {typeof row.free === 'boolean' ? (
                          row.free ? (
                            <Check class="h-5 w-5 mx-auto text-emerald-500" />
                          ) : (
                            <X class="h-5 w-5 mx-auto text-slate-700" />
                          )
                        ) : (
                          <span class="text-sm text-slate-400">{row.free}</span>
                        )}
                      </td>
                      <td class="py-4 px-6 text-center bg-[#22d3ee]/[0.03]">
                        {typeof row.pro === 'boolean' ? (
                          row.pro ? (
                            <Check class="h-5 w-5 mx-auto text-emerald-500" />
                          ) : (
                            <X class="h-5 w-5 mx-auto text-slate-700" />
                          )
                        ) : (
                          <span class="text-sm text-white font-medium">{row.pro}</span>
                        )}
                      </td>
                      <td class="py-4 px-6 text-center">
                        {typeof row.agency === 'boolean' ? (
                          row.agency ? (
                            <Check class="h-5 w-5 mx-auto text-emerald-500" />
                          ) : (
                            <X class="h-5 w-5 mx-auto text-slate-700" />
                          )
                        ) : (
                          <span class="text-sm text-slate-400">{row.agency}</span>
                        )}
                      </td>
                    </tr>
                  ))}
                </>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FREE TIER HIGHLIGHT
       ============================================================ -->
  <section class="py-24 sm:py-28" style="background:#040c1e;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-emerald-500/20 bg-emerald-500/[0.03] p-8 md:p-12">
        <div class="grid gap-10 md:grid-cols-2 items-center">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 px-3 py-1 text-sm font-medium text-emerald-400 mb-5">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
              Free forever
            </div>
            <h2 class="text-2xl font-bold text-white md:text-3xl leading-tight">
              Full Analysis Power.<br />Zero Cost.
            </h2>
            <p class="mt-4 text-slate-400 leading-relaxed">
              Unlike competitors that gate checks behind paid tiers, Crawlix gives you every SEO check for free.
              {totalSeoChecks}+ checks, Core Web Vitals, JavaScript rendering, AI readiness audits — all included.
            </p>
            <p class="mt-3 text-slate-500 text-sm">
              The only limits are page count (100/crawl) and export formats. Upgrade when you need more scale.
            </p>
            <div class="mt-8">
              <a href="/download" class="group inline-flex items-center gap-2 rounded-xl bg-emerald-500 px-7 py-3.5 font-semibold text-white hover:bg-emerald-400 transition-all shadow-lg shadow-emerald-500/20">
                <Download class="h-5 w-5" />
                Download Free
                <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
              </a>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            {[
              { label: `${totalSeoChecks}+ SEO checks`, desc: 'Every check, every tier' },
              { label: 'Core Web Vitals', desc: 'LCP, CLS, INP, FCP, TTFB' },
              { label: 'JavaScript rendering', desc: 'Full Chromium engine' },
              { label: 'AI search readiness', desc: '13 AI crawler checks' },
              { label: 'Accessibility audit', desc: 'WCAG 2.1 AA checks' },
              { label: 'Schema validation', desc: 'JSON-LD, microdata, OG' },
            ].map(({ label, desc }) => (
              <div class="p-3 rounded-lg bg-slate-900/40 border border-slate-800/40">
                <div class="flex items-center gap-2 mb-1">
