<style>
  details[open] summary {
    background-color: rgba(30, 41, 59, 0.2);
  }

  .billing-active {
    background: rgba(34, 211, 238, 0.15);
    color: #22d3ee;
    border: 1px solid rgba(34, 211, 238, 0.2);
  }
  .billing-inactive {
    color: #94a3b8;
    border: 1px solid transparent;
  }
  .billing-inactive:hover {
    color: #fff;
  }

  /* Price crossfade animation */
  .price-monthly,
  .price-annual,
  .price-perpetual {
    transition: opacity 0.2s ease-out, transform 0.2s ease-out;
  }
  .price-monthly.hidden,
  .price-annual.hidden,
  .price-perpetual.hidden {
    opacity: 0;
    transform: translateY(-8px);
    pointer-events: none;
    position: absolute;
  }
  .price-monthly:not(.hidden),
  .price-annual:not(.hidden),
  .price-perpetual:not(.hidden) {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .price-monthly,
    .price-annual,
    .price-perpetual {
      transition: none !important;
    }
  }

  /* Asymmetric card sizing */
  .pricing-card-pro {
    transform: scale(1.05);
    z-index: 10;
  }
  @media (max-width: 1023px) {
    .pricing-card-pro {
      transform: none;
    }
  }

  .pricing-node {
    animation: pricing-pulse 4s ease-in-out infinite;
  }
  .pricing-edge {
    animation: pricing-breathe 5s ease-in-out infinite;
  }
  @keyframes pricing-pulse {
    0%, 100% { opacity: var(--base-opacity); }
    50% { opacity: calc(var(--base-opacity) * 1.8); }
  }
  @keyframes pricing-breathe {
    0%, 100% { opacity: var(--base-opacity); }
    50% { opacity: calc(var(--base-opacity) * 2.2); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pricing-node, .pricing-edge { animation: none !important; }
  }
</style>

<script>
  const LEMON_SQUEEZY_STORE = 'https://crawlix.lemonsqueezy.com';

  let currentBilling = 'annual';

  function getCheckoutUrl(variantId: string): string {
    const params = new URLSearchParams();
    params.set('embed', '0');
    params.set('dark', '1');
    return `${LEMON_SQUEEZY_STORE}/checkout/buy/${variantId}?${params.toString()}`;
  }

  function updateCheckoutLinks() {
    const checkoutBtns = document.querySelectorAll('.checkout-btn');
    checkoutBtns.forEach(btn => {
      const variantKey = `data-variant-${currentBilling === 'annual' ? 'yearly' : currentBilling}`;
      const variantId = btn.getAttribute(variantKey);
      if (variantId) {
        btn.setAttribute('href', getCheckoutUrl(variantId));
      }
    });
  }

  const billingBtns = document.querySelectorAll('.billing-btn');
  const monthlyPrices = document.querySelectorAll('.price-monthly');
  const annualPrices = document.querySelectorAll('.price-annual');
  const perpetualPrices = document.querySelectorAll('.price-perpetual');

  billingBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const billing = btn.getAttribute('data-billing');
      if (!billing) return;

      currentBilling = billing;

      // Update button styles
      billingBtns.forEach(b => {
        if (b.getAttribute('data-billing') === billing) {
          b.classList.add('billing-active');
          b.classList.remove('billing-inactive');
        } else {
          b.classList.remove('billing-active');
          b.classList.add('billing-inactive');
        }
      });

      // Toggle prices
      monthlyPrices.forEach(el => el.classList.toggle('hidden', billing !== 'monthly'));
      annualPrices.forEach(el => el.classList.toggle('hidden', billing !== 'annual'));
      perpetualPrices.forEach(el => el.classList.toggle('hidden', billing !== 'perpetual'));

      // Update checkout links
      updateCheckoutLinks();
    });
  });

  // Initialize checkout links on page load
  updateCheckoutLinks();

  // Scroll animations
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    document.querySelectorAll('.animate-on-scroll').forEach(el => {
      observer.observe(el);
    });

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', (e) => {
        const href = anchor.getAttribute('href');
        if (href && href.startsWith('#')) {
          e.preventDefault();
          const target = document.querySelector(href);
          if (target) {
            const offset = 80;
            const pos = target.getBoundingClientRect().top + window.pageYOffset - offset;
            window.scrollTo({ top: pos, behavior: 'smooth' });
          }
        }
      });
    });
  });
</script>
