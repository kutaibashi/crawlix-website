---
import { getCollection, render } from 'astro:content';
import { docSections } from '../../data/docs';
import DocLayout from '../../layouts/DocLayout.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { ChevronRight, ArrowLeft, ArrowRight } from '@lucide/astro';

export const prerender = true;

export async function getStaticPaths() {
  const allDocs = await getCollection('docs');

  // Section paths (list pages)
  const sectionPaths = docSections.map((section) => ({
    params: { slug: section.id },
    props: { type: 'section' as const, section },
  }));

  // Article paths
  const articlePaths = allDocs.map((entry) => {
    const section = docSections.find((s) => s.articles.some((a) => a.slug === entry.id));
    const articleMeta = section?.articles.find((a) => a.slug === entry.id);

    // Find prev/next in section
    const sectionArticles = section?.articles ?? [];
    const idx = sectionArticles.findIndex((a) => a.slug === entry.id);
    const prev = idx > 0 ? sectionArticles[idx - 1] : null;
    const next = idx < sectionArticles.length - 1 ? sectionArticles[idx + 1] : null;

    return {
      params: { slug: entry.id },
      props: {
        type: 'article' as const,
        entry,
        section: section ?? null,
        articleMeta: articleMeta ?? null,
        prev,
        next,
      },
    };
  });

  return [...sectionPaths, ...articlePaths];
}

const { type } = Astro.props;

let Content: any = null;
if (type === 'article') {
  const { entry } = Astro.props as any;
  const rendered = await render(entry);
  Content = rendered.Content;
}

const badgeLabel: Record<string, string> = {
  new: 'New',
  updated: 'Updated',
  pro: 'Pro',
  agency: 'Agency',
};

const badgeClass: Record<string, string> = {
  new: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/30',
  updated: 'text-amber-400 bg-amber-500/10 border-amber-500/30',
  pro: 'text-[#22d3ee] bg-cyan-500/10 border-cyan-500/30',
  agency: 'text-[#a78bfa] bg-violet-500/10 border-violet-500/30',
};
---

{type === 'section' && (() => {
  const { section } = Astro.props as any;
  return (
    <BaseLayout
      title={`${section.title} - Crawlix Docs`}
      description={section.description}
      breadcrumbs={[
        { name: 'Home', url: '/' },
        { name: 'Docs', url: '/docs' },
        { name: section.title, url: `/docs/${section.id}` },
      ]}
    >
      <a href="#main-content" class="skip-link">Skip to main content</a>
      <Header slot="header" />

      <div style="background: #040c1e;">

        <!-- Hero -->
        <section
          class="relative pt-32 pb-12 overflow-hidden"
          style="background: radial-gradient(ellipse 60% 50% at 50% 40%, #0c2340, #040c1e);"
        >
          <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
            <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-slate-600 mb-8">
              <a href="/" class="hover:text-slate-400 transition-colors">Home</a>
              <ChevronRight class="h-3 w-3" />
              <a href="/docs" class="hover:text-slate-400 transition-colors">Docs</a>
              <ChevronRight class="h-3 w-3" />
              <span class="text-slate-400">{section.title}</span>
            </nav>

            <div class="max-w-2xl">
              <h1 class="text-3xl font-bold text-white sm:text-4xl leading-snug">
                {section.title}
              </h1>
              <p class="mt-4 text-lg text-slate-400">{section.description}</p>
              <p class="mt-2 text-sm text-slate-500">{section.articles.length} articles in this section</p>
            </div>
          </div>
        </section>

        <!-- Articles List -->
        <section id="main-content" class="py-14 border-t border-slate-800/30">
          <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
            <div class="max-w-3xl">
              {section.articles.map((article: any, i: number) => (
                <a href={`/docs/${article.slug}`} class="group block py-5 border-t border-slate-800/30 first:border-t-0">
                  <div class="flex items-start gap-4">
                    <span class="shrink-0 text-slate-600 text-sm w-5 text-right">{i + 1}</span>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 flex-wrap">
                        <h2 class="text-base font-semibold text-white group-hover:text-[#22d3ee] transition-colors">
                          {article.title}
                        </h2>
                        {article.badge && (
                          <span class={`inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-medium ${badgeClass[article.badge]}`}>
                            {badgeLabel[article.badge]}
                          </span>
                        )}
                      </div>
                      <p class="mt-1 text-sm text-slate-400">{article.description}</p>
                    </div>
                    <ArrowRight class="h-4 w-4 text-slate-600 group-hover:text-[#22d3ee] transition-colors shrink-0 mt-1" />
                  </div>
                </a>
              ))}
            </div>

            <!-- Back link -->
            <div class="mt-10 pt-6 border-t border-slate-800/30">
              <a href="/docs" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-300 transition-colors">
                <ArrowLeft class="h-4 w-4" />
                Back to all documentation
              </a>
            </div>
          </div>
        </section>

      </div>

      <Footer slot="footer" />
    </BaseLayout>
  );
})()}

{type === 'article' && (() => {
  const { entry, section, articleMeta, prev, next } = Astro.props as any;
  const data = entry.data;
  return (
    <DocLayout
      title={data.title}
      description={data.description || ''}
      badge={data.badge}
      sectionId={section?.id ?? ''}
      sectionTitle={section?.title ?? 'Docs'}
      articleSlug={entry.id}
      prevArticle={prev}
      nextArticle={next}
    >
      {Content && <Content />}
    </DocLayout>
  );
})()}
