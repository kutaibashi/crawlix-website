---
/**
 * Free vs Pro — quick comparison showing what you get at each tier.
 * Focused on limits, not full feature lists.
 */
import { Check, ArrowRight } from '@lucide/astro';

const rows = [
  { feature: 'SEO checks', free: 'All 100+', pro: 'All 100+', agency: 'All 100+' },
  { feature: 'Pages per crawl', free: '100', pro: '50,000', agency: 'Unlimited' },
  { feature: 'Projects', free: '1', pro: '20', agency: 'Unlimited' },
  { feature: 'Scheduled crawls', free: '—', pro: '5', agency: 'Unlimited' },
  { feature: 'Custom extraction', free: '5 rules', pro: '15 rules', agency: 'Unlimited' },
  { feature: 'White-label reports', free: '—', pro: '—', agency: true },
  { feature: 'Team seats', free: '1', pro: '1', agency: '5' },
];

function renderCell(value: string | boolean) {
  if (value === true) return { type: 'check' };
  if (value === '—') return { type: 'dash' };
  return { type: 'text', value: String(value) };
}
---

<section class="py-24 sm:py-32 bg-gradient-to-b from-[#091a3d] via-[#0b1e44] to-[#091a3d]">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <span class="inline-block text-sm font-semibold text-cyan-400 uppercase tracking-widest mb-4">
        Plans
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Same engine, every tier
      </h2>
      <p class="mt-4 text-lg text-slate-400 max-w-xl mx-auto">
        All 100+ SEO checks are included free. Upgrade for more pages, automation, and team features.
      </p>
    </div>

    <!-- Comparison Table -->
    <div class="overflow-hidden rounded-2xl border border-slate-800">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-[#0e2655]">
            <th class="px-5 py-4 text-left text-slate-400 font-medium"></th>
            <th class="px-5 py-4 text-center">
              <div class="text-slate-300 font-semibold">Free</div>
              <div class="text-xs text-slate-500 mt-0.5">$0 forever</div>
            </th>
            <th class="px-5 py-4 text-center">
              <div class="text-cyan-400 font-semibold">Pro</div>
              <div class="text-xs text-slate-500 mt-0.5">One-time purchase</div>
            </th>
            <th class="px-5 py-4 text-center">
              <div class="text-violet-400 font-semibold">Agency</div>
              <div class="text-xs text-slate-500 mt-0.5">One-time purchase</div>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800/60">
          {rows.map(({ feature, free, pro, agency }, i) => {
            const freeCell = renderCell(free);
            const proCell = renderCell(pro);
            const agencyCell = renderCell(agency);

            return (
              <tr class={i % 2 === 0 ? 'bg-[#091a3d]' : 'bg-[#0a1d42]'}>
                <td class="px-5 py-3.5 text-slate-300 font-medium">{feature}</td>
                <td class="px-5 py-3.5 text-center">
                  {freeCell.type === 'check' && <Check class="h-5 w-5 text-emerald-400 mx-auto" />}
                  {freeCell.type === 'dash' && <span class="text-slate-600">—</span>}
                  {freeCell.type === 'text' && <span class="text-slate-300">{freeCell.value}</span>}
                </td>
                <td class="px-5 py-3.5 text-center">
                  {proCell.type === 'check' && <Check class="h-5 w-5 text-emerald-400 mx-auto" />}
                  {proCell.type === 'dash' && <span class="text-slate-600">—</span>}
                  {proCell.type === 'text' && <span class="text-cyan-300">{proCell.value}</span>}
                </td>
                <td class="px-5 py-3.5 text-center">
                  {agencyCell.type === 'check' && <Check class="h-5 w-5 text-emerald-400 mx-auto" />}
                  {agencyCell.type === 'dash' && <span class="text-slate-600">—</span>}
                  {agencyCell.type === 'text' && <span class="text-violet-300">{agencyCell.value}</span>}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <!-- CTA row -->
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/download" class="inline-flex items-center gap-2 rounded-lg bg-cyan-600 px-6 py-3 font-semibold text-white hover:bg-cyan-500 transition-colors">
        Download Free
      </a>
      <a href="/pricing" class="inline-flex items-center gap-2 text-slate-400 hover:text-cyan-400 font-medium transition-colors">
        See full pricing
        <ArrowRight class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>
