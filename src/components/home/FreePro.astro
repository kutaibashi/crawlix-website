---
/**
 * Free vs Pro vs Agency — clean comparison table.
 * Thin lines, no heavy card wrapper, minimal aesthetic.
 */
import { Check, ArrowRight } from '@lucide/astro';

const rows = [
  { feature: 'SEO checks', free: 'All 100+', pro: 'All 100+', agency: 'All 100+' },
  { feature: 'Pages per crawl', free: '100', pro: '50,000', agency: 'Unlimited' },
  { feature: 'Projects', free: '1', pro: '20', agency: 'Unlimited' },
  { feature: 'Scheduled crawls', free: '—', pro: '5', agency: 'Unlimited' },
  { feature: 'Custom extraction', free: '5 rules', pro: '15 rules', agency: 'Unlimited' },
  { feature: 'White-label reports', free: '—', pro: '—', agency: true },
  { feature: 'Team seats', free: '1', pro: '1', agency: '5' },
];

function renderCell(value: string | boolean) {
  if (value === true) return { type: 'check' };
  if (value === '—') return { type: 'dash' };
  return { type: 'text', value: String(value) };
}
---

<section class="py-24 sm:py-32 bg-[#060f24]">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header — left-aligned with bar -->
    <div class="section-header-bar mb-12">
      <span class="text-sm font-semibold text-[#22d3ee] uppercase tracking-widest">Plans</span>
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl mt-2">
        Same engine, every tier
      </h2>
      <p class="mt-3 text-base text-slate-400 max-w-xl">
        All 100+ SEO checks are included free. Upgrade for more pages, automation, and team features.
      </p>
    </div>

    <!-- Table -->
    <div class="overflow-hidden rounded-xl border border-slate-800/60">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-800/60">
            <th class="px-5 py-4 text-left text-slate-500 font-medium text-xs uppercase tracking-wider"></th>
            <th class="px-5 py-4 text-center">
              <div class="text-slate-300 font-semibold">Free</div>
              <div class="text-xs text-slate-600 mt-0.5">$0 forever</div>
            </th>
            <th class="px-5 py-4 text-center">
              <div class="text-[#22d3ee] font-semibold">Pro</div>
              <div class="text-xs text-slate-600 mt-0.5">One-time purchase</div>
            </th>
            <th class="px-5 py-4 text-center">
              <div class="text-violet-400 font-semibold">Agency</div>
              <div class="text-xs text-slate-600 mt-0.5">One-time purchase</div>
            </th>
          </tr>
        </thead>
        <tbody>
          {rows.map(({ feature, free, pro, agency }, i) => {
            const freeCell = renderCell(free);
            const proCell = renderCell(pro);
            const agencyCell = renderCell(agency);

            return (
              <tr class="border-b border-slate-800/30 last:border-b-0">
                <td class="px-5 py-3.5 text-slate-400 font-medium">{feature}</td>
                <td class="px-5 py-3.5 text-center">
                  {freeCell.type === 'check' && <Check class="h-4 w-4 text-emerald-400 mx-auto" />}
                  {freeCell.type === 'dash' && <span class="text-slate-700">—</span>}
                  {freeCell.type === 'text' && <span class="text-slate-300">{freeCell.value}</span>}
                </td>
                <td class="px-5 py-3.5 text-center">
                  {proCell.type === 'check' && <Check class="h-4 w-4 text-emerald-400 mx-auto" />}
                  {proCell.type === 'dash' && <span class="text-slate-700">—</span>}
                  {proCell.type === 'text' && <span class="text-[#a5f3fc]">{proCell.value}</span>}
                </td>
                <td class="px-5 py-3.5 text-center">
                  {agencyCell.type === 'check' && <Check class="h-4 w-4 text-emerald-400 mx-auto" />}
                  {agencyCell.type === 'dash' && <span class="text-slate-700">—</span>}
                  {agencyCell.type === 'text' && <span class="text-violet-300">{agencyCell.value}</span>}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <!-- CTAs -->
    <div class="mt-8 flex flex-col sm:flex-row items-start gap-4">
      <a href="/download" class="inline-flex items-center gap-2 rounded-lg bg-[#22d3ee] px-5 py-2.5 font-semibold text-slate-900 hover:bg-[#67e8f9] transition-colors text-sm">
        Download Free
      </a>
      <a href="/pricing" class="inline-flex items-center gap-2 text-slate-500 hover:text-[#22d3ee] font-medium transition-colors text-sm">
        See full pricing
        <ArrowRight class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>
