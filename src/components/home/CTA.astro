---
import { Download, Monitor, ArrowRight } from '@lucide/astro';
---

<section class="py-20 sm:py-28 relative overflow-hidden bg-[#091a3d]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl">
      <!-- Gradient background -->
      <div class="absolute inset-0 bg-gradient-to-br from-[#0891b2] via-[#06b6d4] to-[#0e7490]"></div>

      <!-- Dot grid overlay -->
      <div class="absolute inset-0 opacity-10">
        <div class="absolute inset-0" style="background-image:radial-gradient(circle,rgba(255,255,255,0.3) 1px,transparent 1px);background-size:24px 24px;"></div>
      </div>

      <!-- Content -->
      <div class="relative px-6 py-16 sm:px-16 sm:py-20 text-center">
        <div class="mb-5 inline-flex items-center gap-2 rounded-full bg-white/10 backdrop-blur-sm px-4 py-2 text-sm text-white/90">
          <span class="node-dot" style="background:white;box-shadow:none;width:6px;height:6px;"></span>
          Now available for Windows & Linux
        </div>

        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          Ready to Audit Your First Website?
        </h2>
        <p class="mx-auto mt-5 max-w-xl text-lg text-cyan-100/80 leading-relaxed">
          Download Crawlix and find SEO issues in minutes.
          <br />
          <span class="font-semibold text-white">No account. No credit card. No data uploaded.</span>
        </p>

        <!-- CTA buttons -->
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/download" class="group inline-flex items-center gap-2 rounded-xl bg-white px-8 py-4 font-semibold text-cyan-700 shadow-lg hover:bg-cyan-50 transition-all hover:shadow-xl">
            <Download class="h-5 w-5" />
            Download for Free
            <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </a>
          <a href="/features" class="inline-flex items-center gap-2 rounded-xl border-2 border-white/30 bg-white/10 backdrop-blur-sm px-8 py-4 font-semibold text-white hover:bg-white/20 transition-colors">
            See All Features
          </a>
        </div>

        <!-- Platform icons -->
        <div class="mt-10 flex items-center justify-center gap-8 text-white/70">
          <div class="flex items-center gap-2 text-sm">
            <Monitor class="h-5 w-5" />
            <span>Windows</span>
          </div>
          <div class="flex items-center gap-2 text-sm">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.132 1.884 1.071.771-.06 1.592-.536 2.257-1.306.631-.765 1.683-1.084 2.378-1.503.348-.199.629-.469.649-.853.023-.4-.2-.811-.714-1.376v-.097l-.003-.003c-.17-.2-.25-.535-.338-.926-.085-.401-.182-.786-.492-1.046h-.003c-.059-.054-.123-.067-.188-.135a.357.357 0 00-.19-.064c.431-1.278.264-2.55-.173-3.694-.533-1.41-1.465-2.638-2.175-3.483-.796-1.005-1.576-1.957-1.56-3.368.026-2.152.236-6.133-3.544-6.139z"/>
            </svg>
            <span>Linux</span>
          </div>
        </div>

        <!-- Trust -->
        <div class="mt-6 flex flex-wrap items-center justify-center gap-5 text-sm text-white/50">
          {['No signup required', 'Works offline', 'GDPR compliant'].map(item => (
            <span class="flex items-center gap-1.5">
              <span class="w-1 h-1 rounded-full bg-white/50"></span>
              {item}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
