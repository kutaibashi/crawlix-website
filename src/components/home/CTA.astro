---
import { Download, Monitor, ArrowRight } from '@lucide/astro';

// Small node network for CTA background
const nodes: Array<{ x: number; y: number; opacity: number }> = [];
for (let i = 0; i < 30; i++) {
  nodes.push({
    x: Math.random() * 100,
    y: Math.random() * 100,
    opacity: 0.08 + Math.random() * 0.12,
  });
}
const lines: Array<{ x1: number; y1: number; x2: number; y2: number; opacity: number }> = [];
for (let i = 0; i < nodes.length; i++) {
  for (let j = i + 1; j < nodes.length; j++) {
    const dx = nodes[i].x - nodes[j].x;
    const dy = nodes[i].y - nodes[j].y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < 25 && Math.random() > 0.5) {
      lines.push({ x1: nodes[i].x, y1: nodes[j].y, x2: nodes[j].x, y2: nodes[j].y, opacity: 0.06 });
    }
  }
}
---

<section class="py-20 sm:py-28 relative overflow-hidden bg-[#091a3d]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl">
      <!-- Dark gradient background — much better contrast -->
      <div class="absolute inset-0 bg-gradient-to-br from-[#0c3a5e] via-[#0a2f4d] to-[#061e35]"></div>

      <!-- Node network overlay -->
      <div class="absolute inset-0">
        <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          {lines.map((l) => (
            <line x1={`${l.x1}%`} y1={`${l.y1}%`} x2={`${l.x2}%`} y2={`${l.y2}%`}
              stroke="#22d3ee" stroke-width="0.1" opacity={l.opacity} />
          ))}
          {nodes.map((n) => (
            <circle cx={`${n.x}%`} cy={`${n.y}%`} r="0.3"
              fill="#22d3ee" opacity={n.opacity} />
          ))}
        </svg>
      </div>

      <!-- Subtle cyan glow at top -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[200px] bg-[#22d3ee]/8 rounded-full blur-[80px]"></div>

      <!-- Content -->
      <div class="relative px-6 py-16 sm:px-16 sm:py-20 text-center">
        <div class="mb-5 inline-flex items-center gap-2 rounded-full bg-[#22d3ee]/10 border border-[#22d3ee]/15 px-4 py-2 text-sm text-[#22d3ee]">
          <span class="w-1.5 h-1.5 rounded-full bg-[#22d3ee]"></span>
          Now available for Windows & Linux
        </div>

        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          Ready to Audit Your First Website?
        </h2>
        <p class="mx-auto mt-5 max-w-xl text-lg text-slate-300 leading-relaxed">
          Download Crawlix and find SEO issues in minutes.
          <br />
          <span class="font-semibold text-white">No account. No credit card. No data uploaded.</span>
        </p>

        <!-- CTA buttons -->
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/download" class="group inline-flex items-center gap-2 rounded-xl bg-[#22d3ee] px-8 py-4 font-semibold text-slate-900 hover:bg-[#67e8f9] transition-all">
            <Download class="h-5 w-5" />
            Download for Free
            <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </a>
          <a href="/features" class="inline-flex items-center gap-2 rounded-xl border border-white/20 bg-white/5 px-8 py-4 font-semibold text-white hover:bg-white/10 transition-colors">
            See All Features
          </a>
        </div>

        <!-- Platform icons -->
        <div class="mt-10 flex items-center justify-center gap-8 text-slate-400">
          <div class="flex items-center gap-2 text-sm">
            <Monitor class="h-5 w-5" />
            <span>Windows</span>
          </div>
          <div class="flex items-center gap-2 text-sm">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.132 1.884 1.071.771-.06 1.592-.536 2.257-1.306.631-.765 1.683-1.084 2.378-1.503.348-.199.629-.469.649-.853.023-.4-.2-.811-.714-1.376v-.097l-.003-.003c-.17-.2-.25-.535-.338-.926-.085-.401-.182-.786-.492-1.046h-.003c-.059-.054-.123-.067-.188-.135a.357.357 0 00-.19-.064c.431-1.278.264-2.55-.173-3.694-.533-1.41-1.465-2.638-2.175-3.483-.796-1.005-1.576-1.957-1.56-3.368.026-2.152.236-6.133-3.544-6.139z"/>
            </svg>
            <span>Linux</span>
          </div>
        </div>

        <!-- Trust -->
        <div class="mt-6 flex flex-wrap items-center justify-center gap-5 text-sm text-slate-400">
          {['No signup required', 'Works offline', 'GDPR compliant'].map(item => (
            <span class="flex items-center gap-1.5">
              <span class="w-1 h-1 rounded-full bg-slate-500"></span>
              {item}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
