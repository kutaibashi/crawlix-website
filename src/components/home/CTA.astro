---
import { Download, Monitor, ArrowRight } from '@lucide/astro';

// Converging network — nodes scattered across the area, each connected
// by a line toward the center point. Lines are directional, creating
// a visual flow like data routing to a destination.
const centerX = 50;
const centerY = 48;

const nodes: Array<{ x: number; y: number; size: number; opacity: number; delay: number; dist: number }> = [];

// Scatter 50 nodes across the full area
for (let i = 0; i < 50; i++) {
  const x = 5 + Math.random() * 90;
  const y = 5 + Math.random() * 90;
  const dx = x - centerX;
  const dy = y - centerY;
  const dist = Math.sqrt(dx * dx + dy * dy);

  // Closer nodes are bigger and brighter
  const maxDist = 55;
  const proximity = 1 - Math.min(dist / maxDist, 1);
  const size = 1 + proximity * 2.5;
  const opacity = 0.05 + proximity * 0.2;

  nodes.push({ x, y, size, opacity, delay: Math.random() * 6, dist });
}

// Connection lines: each node connects toward center via
// an intermediate node that's closer to center (creating flow paths)
const flowLines: Array<{ x1: number; y1: number; x2: number; y2: number; opacity: number; delay: number }> = [];

for (const node of nodes) {
  // Draw a line from this node partway toward center
  const dx = centerX - node.x;
  const dy = centerY - node.y;
  const dist = Math.sqrt(dx * dx + dy * dy);

  if (dist > 8) {
    // Line goes 30-50% of the way toward center
    const t = 0.3 + Math.random() * 0.2;
    const endX = node.x + dx * t;
    const endY = node.y + dy * t;
    const proximity = 1 - Math.min(dist / 55, 1);
    flowLines.push({
      x1: node.x, y1: node.y,
      x2: endX, y2: endY,
      opacity: 0.04 + proximity * 0.08,
      delay: node.delay,
    });
  }
}

// Also connect nearby nodes to each other (lateral connections)
for (let i = 0; i < nodes.length; i++) {
  for (let j = i + 1; j < nodes.length; j++) {
    const dx = nodes[i].x - nodes[j].x;
    const dy = nodes[i].y - nodes[j].y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < 12 && Math.random() > 0.6) {
      flowLines.push({
        x1: nodes[i].x, y1: nodes[i].y,
        x2: nodes[j].x, y2: nodes[j].y,
        opacity: 0.04,
        delay: 0,
      });
    }
  }
}
---

<section class="py-24 sm:py-32 relative overflow-hidden" style="background:#040c1e;">
  <!-- Converging node network -->
  <div class="absolute inset-0">
    <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      {/* Flow lines — pointing toward center */}
      {flowLines.map((l) => (
        <line
          x1={`${l.x1}%`} y1={`${l.y1}%`}
          x2={`${l.x2}%`} y2={`${l.y2}%`}
          stroke="#22d3ee" stroke-width="0.06"
          opacity={l.opacity}
          class="cta-flow"
          style={`animation-delay:${l.delay}s;`}
        />
      ))}
      {/* Nodes */}
      {nodes.map((n) => (
        <circle
          cx={`${n.x}%`} cy={`${n.y}%`}
          r={n.size * 0.12}
          fill="#22d3ee"
          opacity={n.opacity}
          class="cta-node"
          style={`animation-delay:${n.delay}s;`}
        />
      ))}
      {/* Center node — larger, brighter */}
      <circle cx={`${centerX}%`} cy={`${centerY}%`} r="0.5" fill="#22d3ee" opacity="0.4" class="cta-center" />
      <circle cx={`${centerX}%`} cy={`${centerY}%`} r="1.2" fill="none" stroke="#22d3ee" stroke-width="0.08" opacity="0.15" />
      <circle cx={`${centerX}%`} cy={`${centerY}%`} r="2.5" fill="none" stroke="#22d3ee" stroke-width="0.05" opacity="0.08" />
    </svg>
  </div>

  <!-- Center glow -->
  <div class="absolute top-[45%] left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] h-[250px] bg-[#22d3ee]/6 rounded-full blur-[80px]"></div>

  <!-- Content -->
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 relative text-center">
    <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-[#22d3ee]/8 border border-[#22d3ee]/15 px-4 py-2 text-sm text-[#22d3ee]">
      <span class="w-1.5 h-1.5 rounded-full bg-[#22d3ee]"></span>
      Now available for Windows & Linux
    </div>

    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
      Ready to Audit Your First Website?
    </h2>

    <p class="mx-auto mt-5 max-w-xl text-lg text-slate-300 leading-relaxed">
      Download Crawlix and find SEO issues in minutes.
      <br />
      <span class="font-semibold text-white">No account. No credit card. No data uploaded.</span>
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/download" class="group inline-flex items-center gap-2 rounded-xl bg-[#22d3ee] px-8 py-4 font-semibold text-slate-900 hover:bg-[#67e8f9] transition-all shadow-lg shadow-[#22d3ee]/20 hover:shadow-[#22d3ee]/30">
        <Download class="h-5 w-5" />
        Download for Free
        <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
      </a>
      <a href="/features" class="inline-flex items-center gap-2 rounded-xl border border-slate-700 bg-slate-800/50 px-8 py-4 font-semibold text-white hover:bg-slate-700/50 transition-colors">
        See All Features
      </a>
    </div>

    <div class="mt-10 flex items-center justify-center gap-8 text-slate-500">
      <div class="flex items-center gap-2 text-sm">
        <Monitor class="h-4 w-4" />
        <span>Windows</span>
      </div>
      <div class="flex items-center gap-2 text-sm">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.132 1.884 1.071.771-.06 1.592-.536 2.257-1.306.631-.765 1.683-1.084 2.378-1.503.348-.199.629-.469.649-.853.023-.4-.2-.811-.714-1.376v-.097l-.003-.003c-.17-.2-.25-.535-.338-.926-.085-.401-.182-.786-.492-1.046h-.003c-.059-.054-.123-.067-.188-.135a.357.357 0 00-.19-.064c.431-1.278.264-2.55-.173-3.694-.533-1.41-1.465-2.638-2.175-3.483-.796-1.005-1.576-1.957-1.56-3.368.026-2.152.236-6.133-3.544-6.139z"/>
        </svg>
        <span>Linux</span>
      </div>
    </div>

    <div class="mt-5 flex flex-wrap items-center justify-center gap-5 text-xs text-slate-500">
      {['No signup required', 'Works offline', 'GDPR compliant'].map(item => (
        <span class="flex items-center gap-1.5">
          <span class="w-1 h-1 rounded-full bg-emerald-500/50"></span>
          {item}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  .cta-node {
    animation: cta-pulse 5s ease-in-out infinite;
  }
  .cta-flow {
    animation: cta-flow-pulse 6s ease-in-out infinite;
  }
  .cta-center {
    animation: cta-center-pulse 3s ease-in-out infinite;
  }
  @keyframes cta-pulse {
    0%, 100% { opacity: var(--tw-opacity, 0.1); }
    50% { opacity: calc(var(--tw-opacity, 0.1) * 2.2); }
  }
  @keyframes cta-flow-pulse {
    0%, 100% { opacity: var(--tw-opacity, 0.05); }
    50% { opacity: calc(var(--tw-opacity, 0.05) * 2.5); }
  }
  @keyframes cta-center-pulse {
    0%, 100% { opacity: 0.3; r: 0.5; }
    50% { opacity: 0.6; r: 0.7; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cta-node, .cta-flow, .cta-center { animation: none !important; }
  }
</style>
