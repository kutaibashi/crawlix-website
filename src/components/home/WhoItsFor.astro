---
/**
 * Who It's For — three personas in a horizontal layout
 * with accent-colored left borders and no card wrappers.
 * Visually distinct via deeper background + border accents.
 */
---

<section class="py-24 sm:py-32 relative overflow-hidden" style="background:#050e22;">
  <!-- Dot grid -->
  <div class="absolute inset-0 dot-grid opacity-20"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="inline-flex items-center gap-2 text-sm font-semibold text-[#22d3ee] uppercase tracking-widest mb-4">
        <span class="node-dot" style="width:6px;height:6px;"></span>
        Built For You
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Whether you're solo or a team of 50
      </h2>
      <p class="mt-3 text-base text-slate-400 max-w-xl mx-auto">
        Same powerful engine, tailored for your workflow.
      </p>
    </div>

    <!-- Three personas — border-left accent, no card wrapper -->
    <div class="grid gap-10 lg:grid-cols-3">
      <!-- Freelancers -->
      <div class="border-l-2 border-[#22d3ee] pl-6">
        <h3 class="text-xl font-bold text-white mb-2">Freelancers</h3>
        <p class="text-slate-400 text-sm leading-relaxed mb-5">
          Deliver professional SEO audits without monthly subscriptions eating into your margins.
        </p>
        <ul class="space-y-2.5">
          <li class="flex items-start gap-2.5 text-sm text-slate-300">
            <span class="w-1.5 h-1.5 rounded-full bg-[#22d3ee] mt-1.5 flex-shrink-0"></span>
            One-time purchase, use forever
          </li>
          <li class="flex items-start gap-2.5 text-sm text-slate-300">
            <span class="w-1.5 h-1.5 rounded-full bg-[#22d3ee] mt-1.5 flex-shrink-0"></span>
            White-label reports with your branding
          </li>
          <li class="flex items-start gap-2.5 text-sm text-slate-300">
            <span class="w-1.5 h-1.5 rounded-full bg-[#22d3ee] mt-1.5 flex-shrink-0"></span>
            No per-client or per-project fees
          </li>
        </ul>
      </div>

      <!-- Agencies -->
      <div class="border-l-2 border-violet-500 pl-6">
        <h3 class="text-xl font-bold text-white mb-2">Agencies</h3>
        <p class="text-slate-400 text-sm leading-relaxed mb-5">
          Scale SEO audits across your team with 5 device seats, custom branding, and client-ready reports.
        </p>
        <ul class="space-y-2.5">
          <li class="flex items-start gap-2.5 text-sm text-slate-300">
            <span class="w-1.5 h-1.5 rounded-full bg-violet-500 mt-1.5 flex-shrink-0"></span>
            5 device seats for your team
          </li>
          <li class="flex items-start gap-2.5 text-sm text-slate-300">
            <span class="w-1.5 h-1.5 rounded-full bg-violet-500 mt-1.5 flex-shrink-0"></span>
            Custom logo, colors, and fonts in reports
          </li>
          <li class="flex items-start gap-2.5 text-sm text-slate-300">
            <span class="w-1.5 h-1.5 rounded-full bg-violet-500 mt-1.5 flex-shrink-0"></span>
            Scheduled crawls for recurring clients
          </li>
        </ul>
      </div>

      <!-- In-House Teams -->
      <div class="border-l-2 border-amber-500 pl-6">
        <h3 class="text-xl font-bold text-white mb-2">In-House Teams</h3>
        <p class="text-slate-400 text-sm leading-relaxed mb-5">
          Keep all audit data on your own machines. No third-party data processing. GDPR compliance by default.
        </p>
        <ul class="space-y-2.5">
          <li class="flex items-start gap-2.5 text-sm text-slate-300">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500 mt-1.5 flex-shrink-0"></span>
            Data never leaves your infrastructure
          </li>
          <li class="flex items-start gap-2.5 text-sm text-slate-300">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500 mt-1.5 flex-shrink-0"></span>
            No vendor lock-in or data portability issues
          </li>
          <li class="flex items-start gap-2.5 text-sm text-slate-300">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500 mt-1.5 flex-shrink-0"></span>
            Export everything — CSV, PDF, Excel
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
