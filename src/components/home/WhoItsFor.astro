---
/**
 * Who It's For — Target audience section showing 3 personas.
 */
import { Briefcase, Users, User } from '@lucide/astro';

const personas = [
  {
    icon: User,
    title: 'Freelancers',
    description: 'Deliver professional SEO audits to clients without monthly subscriptions eating into your margins.',
    highlights: [
      'One-time purchase, use forever',
      'White-label reports with your branding',
      'No per-client or per-project fees',
    ],
    accent: 'cyan',
  },
  {
    icon: Users,
    title: 'Agencies',
    description: 'Scale SEO audits across your team with 5 device seats, custom branding, and client-ready reports.',
    highlights: [
      '5 device seats for your team',
      'Custom logo, colors, and fonts in reports',
      'Scheduled crawls for recurring clients',
    ],
    accent: 'violet',
  },
  {
    icon: Briefcase,
    title: 'In-House Teams',
    description: 'Keep all audit data on your own machines. No third-party data processing. Full GDPR compliance by default.',
    highlights: [
      'Data never leaves your infrastructure',
      'No vendor lock-in or data portability issues',
      'Export everything — CSV, PDF, Excel',
    ],
    accent: 'amber',
  },
];

const accentClasses = {
  cyan: {
    iconBg: 'bg-cyan-500/10',
    iconText: 'text-cyan-400',
    border: 'border-cyan-500/20',
    hoverBorder: 'hover:border-cyan-500/40',
    bullet: 'text-cyan-400',
  },
  violet: {
    iconBg: 'bg-violet-500/10',
    iconText: 'text-violet-400',
    border: 'border-violet-500/20',
    hoverBorder: 'hover:border-violet-500/40',
    bullet: 'text-violet-400',
  },
  amber: {
    iconBg: 'bg-amber-500/10',
    iconText: 'text-amber-400',
    border: 'border-amber-500/20',
    hoverBorder: 'hover:border-amber-500/40',
    bullet: 'text-amber-400',
  },
};
---

<section class="py-24 sm:py-32 bg-gradient-to-b from-[#091a3d] via-[#0b1e44] to-[#091a3d]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="inline-block text-sm font-semibold text-cyan-400 uppercase tracking-widest mb-4">
        Built For You
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Whether you're solo or a team of 50
      </h2>
      <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">
        Crawlix adapts to how you work. Same powerful engine, tailored for your workflow.
      </p>
    </div>

    <!-- Persona Cards -->
    <div class="grid gap-6 lg:grid-cols-3">
      {personas.map(({ icon: Icon, title, description, highlights, accent }) => {
        const colors = accentClasses[accent as keyof typeof accentClasses];

        return (
          <div class={`relative rounded-2xl border ${colors.border} ${colors.hoverBorder} bg-[#0e2655]/30 p-8 transition-all duration-300 hover:bg-[#0e2655]/50`}>
            {/* Icon */}
            <div class={`flex h-14 w-14 items-center justify-center rounded-2xl ${colors.iconBg} ${colors.iconText} mb-6`}>
              <Icon class="h-7 w-7" />
            </div>

            {/* Title & Description */}
            <h3 class="text-xl font-bold text-white mb-3">{title}</h3>
            <p class="text-slate-400 leading-relaxed mb-6">{description}</p>

            {/* Highlights */}
            <ul class="space-y-3">
              {highlights.map((item) => (
                <li class="flex items-start gap-3 text-sm text-slate-300">
                  <svg class={`h-4 w-4 mt-0.5 flex-shrink-0 ${colors.bullet}`} fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>
  </div>
</section>
