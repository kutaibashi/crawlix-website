---
/**
 * Who It's For — LIGHT background section for visual rhythm break.
 * Uses dark text on off-white, different card aesthetic.
 */
import { Briefcase, Users, User } from '@lucide/astro';

const personas = [
  {
    icon: User,
    title: 'Freelancers',
    description: 'Deliver professional SEO audits without monthly subscriptions eating into your margins.',
    highlights: [
      'One-time purchase, use forever',
      'White-label reports with your branding',
      'No per-client or per-project fees',
    ],
    accent: '#06b6d4',
  },
  {
    icon: Users,
    title: 'Agencies',
    description: 'Scale SEO audits across your team with 5 device seats, custom branding, and client-ready reports.',
    highlights: [
      '5 device seats for your team',
      'Custom logo, colors, and fonts in reports',
      'Scheduled crawls for recurring clients',
    ],
    accent: '#8b5cf6',
  },
  {
    icon: Briefcase,
    title: 'In-House Teams',
    description: 'Keep all audit data on your own machines. No third-party data processing. GDPR compliance by default.',
    highlights: [
      'Data never leaves your infrastructure',
      'No vendor lock-in or data portability issues',
      'Export everything — CSV, PDF, Excel',
    ],
    accent: '#f59e0b',
  },
];
---

<section class="section-light py-24 sm:py-32 relative overflow-hidden">
  <!-- Light dot grid -->
  <div class="absolute inset-0 dot-grid-light"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative">
    <!-- Section Header — centered (light section is a visual break, centered is ok here) -->
    <div class="text-center mb-16">
      <span class="inline-flex items-center gap-2 text-sm font-semibold text-cyan-600 uppercase tracking-widest mb-4">
        <span class="node-dot" style="background:#06b6d4;box-shadow:none;width:6px;height:6px;"></span>
        Built For You
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        Whether you're solo or a team of 50
      </h2>
      <p class="mt-3 text-lg text-slate-500 max-w-2xl mx-auto">
        Crawlix adapts to how you work. Same powerful engine, tailored for your workflow.
      </p>
    </div>

    <!-- Persona Cards — light aesthetic -->
    <div class="grid gap-6 lg:grid-cols-3">
      {personas.map(({ icon: Icon, title, description, highlights, accent }) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm hover:shadow-md hover:border-slate-300 transition-all duration-300">
          {/* Icon */}
          <div class="flex h-12 w-12 items-center justify-center rounded-xl mb-6" style={`background:${accent}10;color:${accent};`}>
            <Icon class="h-6 w-6" />
          </div>

          {/* Title & Description */}
          <h3 class="text-xl font-bold text-slate-900 mb-2">{title}</h3>
          <p class="text-slate-500 leading-relaxed mb-5 text-sm">{description}</p>

          {/* Highlights */}
          <ul class="space-y-2.5">
            {highlights.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-slate-600">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background:${accent};`}></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
