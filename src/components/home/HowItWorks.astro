---
/**
 * How It Works — vertical node timeline with connected dots.
 * Left-aligned header, network aesthetic.
 */
import { Link, Search, BarChart3, FileCheck } from '@lucide/astro';

const steps = [
  {
    title: 'Enter URL',
    description: 'Just paste any website URL. Crawlix maps the entire site structure automatically.',
    Icon: Link,
  },
  {
    title: 'Crawl & Analyze',
    description: '100+ SEO checks run in parallel. JavaScript rendering supported.',
    Icon: Search,
  },
  {
    title: 'Review Issues',
    description: 'Issues organized by priority. Filter by type, page, or severity.',
    Icon: BarChart3,
  },
  {
    title: 'Export Reports',
    description: 'Generate white-label PDF reports with your branding. Share with clients.',
    Icon: FileCheck,
  },
];
---

<section class="py-24 sm:py-32 bg-[#091a3d] relative overflow-hidden" id="how-it-works">
  <div class="absolute inset-0 dot-grid opacity-20"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative">
    <!-- Section Header — left-aligned with bar -->
    <div class="section-header-bar mb-16 max-w-2xl">
      <span class="text-sm font-semibold text-[#22d3ee] uppercase tracking-widest">How It Works</span>
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl mt-2">
        From URL to report in four steps
      </h2>
      <p class="mt-3 text-base text-slate-400">
        No complex setup. Paste a URL and let Crawlix do the work.
      </p>
    </div>

    <!-- Node Timeline -->
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Steps -->
      <div class="relative">
        {steps.map(({ title, description, Icon }, index) => (
          <div class="flex gap-5 mb-10 last:mb-0">
            {/* Node column */}
            <div class="flex flex-col items-center">
              {/* Node dot */}
              <div class="w-10 h-10 rounded-full border-2 border-[#22d3ee]/40 bg-[#060f24] flex items-center justify-center flex-shrink-0 relative z-10">
                <span class="node-dot"></span>
              </div>
              {/* Connecting line */}
              {index < steps.length - 1 && (
                <div class="network-line-solid flex-1 min-h-[40px]"></div>
              )}
            </div>

            {/* Content */}
            <div class="pb-2 pt-1.5">
              <div class="flex items-center gap-2.5 mb-2">
                <Icon class="h-4 w-4 text-[#22d3ee]" />
                <h3 class="text-lg font-semibold text-white">{title}</h3>
              </div>
              <p class="text-slate-400 text-sm leading-relaxed">{description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Right side CTA card -->
      <div class="lg:sticky lg:top-32">
        <div class="rounded-xl border border-slate-800/60 bg-[#060f24] p-8">
          <h3 class="text-white font-semibold mb-2">Ready to try it?</h3>
          <p class="text-slate-400 text-sm mb-6">No account needed. Download and start crawling in seconds.</p>
          <a href="/download" class="inline-flex items-center gap-2 rounded-lg bg-[#22d3ee] px-5 py-2.5 font-semibold text-slate-900 hover:bg-[#67e8f9] transition-colors text-sm">
            Download Free
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
