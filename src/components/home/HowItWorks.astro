---
/**
 * How It Works — horizontal 4-step flow connected by a network line.
 * Compact, visual, node-connected.
 */
import { Link, Search, BarChart3, FileCheck } from '@lucide/astro';

const steps = [
  { num: '01', title: 'Enter URL', description: 'Paste any website URL. Crawlix maps the entire site automatically.', Icon: Link, color: '#22d3ee' },
  { num: '02', title: 'Crawl & Analyze', description: '100+ SEO checks run in parallel. JS rendering supported.', Icon: Search, color: '#a78bfa' },
  { num: '03', title: 'Review Issues', description: 'Issues ranked by impact. Filter by type, page, or severity.', Icon: BarChart3, color: '#fbbf24' },
  { num: '04', title: 'Export Reports', description: 'Generate PDF, Excel, and CSV reports for clients.', Icon: FileCheck, color: '#34d399' },
];
---

<section class="py-24 sm:py-32 bg-[#091a3d] relative overflow-hidden" id="how-it-works">
  <div class="absolute inset-0 dot-grid opacity-20"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="inline-flex items-center gap-2 text-sm font-semibold text-[#22d3ee] uppercase tracking-widest mb-4">
        <span class="node-dot" style="width:6px;height:6px;"></span>
        How It Works
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        From URL to report in four steps
      </h2>
      <p class="mt-3 text-base text-slate-400">
        No complex setup. Paste a URL and let Crawlix do the work.
      </p>
    </div>

    <!-- Steps — horizontal on desktop, vertical on mobile -->
    <div class="relative">
      <!-- Horizontal connecting line (desktop) -->
      <div class="hidden lg:block absolute top-[28px] left-[calc(12.5%+20px)] right-[calc(12.5%+20px)] h-px bg-gradient-to-r from-[#22d3ee]/30 via-[#a78bfa]/30 via-[#fbbf24]/30 to-[#34d399]/30"></div>

      <div class="grid gap-10 lg:grid-cols-4 lg:gap-6">
        {steps.map(({ num, title, description, Icon, color }) => (
          <div class="relative text-center lg:text-center">
            {/* Node */}
            <div class="flex justify-center mb-5">
              <div class="relative">
                <div class="w-14 h-14 rounded-full flex items-center justify-center relative z-10"
                  style={`border: 2px solid ${color}40; background: #091a3d;`}>
                  <Icon class="h-6 w-6" style={`color:${color};`} />
                </div>
                {/* Number badge */}
                <span class="absolute -top-1 -right-1 w-6 h-6 rounded-full text-[10px] font-bold flex items-center justify-center z-20"
                  style={`background:${color}; color:#091a3d;`}>
                  {num}
                </span>
              </div>
            </div>

            {/* Text */}
            <h3 class="text-base font-bold text-white mb-2">{title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed max-w-[220px] mx-auto">{description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-14 text-center">
      <a href="/download" class="inline-flex items-center gap-2 rounded-lg bg-[#22d3ee] px-6 py-3 font-semibold text-slate-900 hover:bg-[#67e8f9] transition-colors text-sm">
        Download Free — No Account Needed
      </a>
    </div>
  </div>
</section>
