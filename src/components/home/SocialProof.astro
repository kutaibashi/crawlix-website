---
// Stats bar — clean numbers with node-dot accents
const highlights = [
  { stat: "100+", label: "SEO Checks", sub: "Technical, content & performance" },
  { stat: "Parallel", label: "Crawling", sub: "Configurable threads" },
  { stat: "2", label: "Platforms", sub: "Windows & Linux" },
  { stat: "100%", label: "Local", sub: "Your data, your machine" },
];
---

<section class="py-12 border-y border-slate-800/40 bg-[#091a3d]">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-6 md:grid-cols-4 md:gap-8">
      {highlights.map(({ stat, label, sub }) => (
        <div class="flex items-start gap-3">
          <span class="node-dot mt-2.5"></span>
          <div>
            <div class="text-2xl font-bold text-white">{stat}</div>
            <div class="text-sm font-medium text-[#22d3ee]">{label}</div>
            <div class="text-xs text-slate-500 mt-0.5">{sub}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
