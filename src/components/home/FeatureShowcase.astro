---
/**
 * Feature Showcase — 3 deep-dive feature sections with alternating layout.
 * Each feature gets a real screenshot + detailed description.
 */
import { ArrowRight } from '@lucide/astro';
import Button from '../ui/Button.astro';

const features = [
  {
    tag: 'Health Score',
    title: 'See your site health at a glance',
    description: 'Crawlix scores your website across 5 categories — Technical, SEO, Content, Performance, and Accessibility. Each category shows exactly what\'s broken and how to fix it. No guesswork.',
    bullets: [
      'Weighted health score across all categories',
      'Per-page issue breakdown with severity levels',
      'Track score changes between crawls',
    ],
    image: '/images/app-preview.png',
    imageAlt: 'Crawlix dashboard showing health score with category breakdown',
  },
  {
    tag: 'AI Search Ready',
    title: 'Prepare for the AI search era',
    description: 'Audit your site for AI crawler compatibility. Check robots.txt rules for GPTBot, Claude-Bot, Google-Extended, and more. Validate your llms.txt file. See exactly what AI crawlers can and can\'t access.',
    bullets: [
      'Audit 13+ AI crawler directives',
      'llms.txt validation and recommendations',
      'AI-specific indexability analysis',
    ],
    image: '/images/app-preview.png',
    imageAlt: 'AI search readiness checks showing crawler directives',
  },
  {
    tag: 'Reports & Export',
    title: 'White-label reports your clients will love',
    description: 'Generate branded PDF reports with your logo, colors, and contact info. Export to CSV or Excel for custom analysis. Schedule recurring crawls and get reports automatically.',
    bullets: [
      'Custom branded PDF reports',
      'CSV and Excel export',
      'Scheduled crawls with automatic reports',
    ],
    image: '/images/app-preview.png',
    imageAlt: 'White-label PDF report with custom branding',
  },
];
---

<section class="py-24 sm:py-32 relative" id="features">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-20">
      <span class="inline-block text-sm font-semibold text-cyan-400 uppercase tracking-widest mb-4">
        Features
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Professional SEO audits,<br />
        <span class="bg-gradient-to-r from-cyan-400 to-sky-400 bg-clip-text text-transparent">without the enterprise price</span>
      </h2>
    </div>

    <!-- Feature Deep-Dives -->
    <div class="space-y-32">
      {features.map((feature, index) => {
        const isReversed = index % 2 === 1;

        return (
          <div class={`flex flex-col gap-12 items-center ${isReversed ? 'lg:flex-row-reverse' : 'lg:flex-row'}`}>
            {/* Text side */}
            <div class="flex-1 max-w-xl">
              <span class="inline-block text-xs font-bold uppercase tracking-widest text-cyan-400 bg-cyan-400/10 px-3 py-1 rounded-full mb-4">
                {feature.tag}
              </span>
              <h3 class="text-2xl sm:text-3xl font-bold text-white mb-4 leading-tight">
                {feature.title}
              </h3>
              <p class="text-slate-400 text-lg leading-relaxed mb-6">
                {feature.description}
              </p>
              <ul class="space-y-3">
                {feature.bullets.map((bullet) => (
                  <li class="flex items-start gap-3 text-slate-300">
                    <svg class="h-5 w-5 text-cyan-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>

            {/* Screenshot side */}
            <div class="flex-1 max-w-2xl w-full">
              <div class="relative group">
                {/* Glow */}
                <div class={`absolute -inset-3 rounded-2xl bg-gradient-to-r ${isReversed ? 'from-indigo-500/20 to-cyan-500/20' : 'from-cyan-500/20 to-sky-500/20'} blur-xl opacity-50 group-hover:opacity-80 transition-opacity duration-500`}></div>
                {/* Image */}
                <div class="relative overflow-hidden rounded-xl border border-slate-700/60 shadow-2xl">
                  <img
                    src={feature.image}
                    alt={feature.imageAlt}
                    width="800"
                    height="500"
                    class="w-full h-auto"
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- See all features link -->
    <div class="mt-20 text-center">
      <a href="/features" class="inline-flex items-center gap-2 text-cyan-400 hover:text-cyan-300 font-semibold transition-colors text-lg">
        Explore all 100+ checks
        <ArrowRight class="h-5 w-5" />
      </a>
    </div>
  </div>
</section>
