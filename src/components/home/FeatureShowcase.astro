---
/**
 * Feature Showcase — 3 deep-dive features with alternating layout
 * and network-line connectors between them.
 */
import { ArrowRight } from '@lucide/astro';

const features = [
  {
    tag: 'Health Score',
    title: 'See your site health at a glance',
    description: 'Crawlix scores your website across 5 categories — Technical, SEO, Content, Performance, and Accessibility. Each category shows exactly what\'s broken and how to fix it.',
    bullets: [
      'Weighted health score across all categories',
      'Per-page issue breakdown with severity levels',
      'Track score changes between crawls',
    ],
    image: '/images/screenshot-dashboard.png',
    imageAlt: 'Crawlix dashboard showing health score with category breakdown',
  },
  {
    tag: 'Issues & Prioritization',
    title: 'Find what matters, fix it first',
    description: 'Every issue is ranked by impact score. See exactly which fixes will move the needle most. Filter by category, severity, or page. Export to CSV or PDF.',
    bullets: [
      'Impact-ranked issue prioritization',
      'Filter by Technical, Content, SEO, Accessibility',
      'Site-wide and per-page issue breakdown',
    ],
    image: '/images/screenshot-issues.png',
    imageAlt: 'Issues view with impact scoring and priority ranking',
  },
  {
    tag: 'AI Search Readiness',
    title: 'Prepare for the AI search era',
    description: 'Audit how AI crawlers see your site. Check robots.txt rules for ChatGPT, Facebook, YouBot and more. Get an AI visibility score and actionable recommendations.',
    bullets: [
      'AI readiness score with visibility rating',
      'Audit 5+ AI crawler directives at once',
      'Generate llms.txt and robots.txt templates',
    ],
    image: '/images/screenshot-ai-readiness.png',
    imageAlt: 'AI Readiness Analysis showing visibility score and crawler status',
  },
  {
    tag: 'White-Label Reports',
    title: 'Your brand, your reports',
    description: 'Customize PDF reports with your company name, logo, brand colors, and typography. Remove "Powered by Crawlix" on Agency tier. Deliver client-ready audits.',
    bullets: [
      'Custom logo, colors, and fonts in reports',
      'Remove Crawlix branding on Agency tier',
      'Export to PDF, Excel, CSV, or HTML',
    ],
    image: '/images/screenshot-whitelabel.png',
    imageAlt: 'White-label branding settings with logo upload and color picker',
  },
];
---

<section class="py-24 sm:py-32 bg-[#091a3d] relative overflow-hidden" id="features">
  <!-- Dot grid -->
  <div class="absolute inset-0 dot-grid opacity-30"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative">
    <!-- Section Header — left-aligned with bar -->
    <div class="section-header-bar mb-16 max-w-2xl">
      <span class="text-sm font-semibold text-[#22d3ee] uppercase tracking-widest">Features</span>
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl mt-2">
        Professional SEO audits, without the enterprise price
      </h2>
    </div>

    <!-- Feature Deep-Dives with network connectors -->
    <div class="relative">
      {features.map((feature, index) => {
        const isReversed = index % 2 === 1;
        const isLast = index === features.length - 1;

        return (
          <div>
            {/* Feature block */}
            <div class={`flex flex-col gap-10 items-center ${isReversed ? 'lg:flex-row-reverse' : 'lg:flex-row'} mb-8`}>
              {/* Text side */}
              <div class="flex-1 max-w-xl">
                <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#22d3ee] mb-4">
                  <span class="node-dot" style="width:6px;height:6px;"></span>
                  {feature.tag}
                </span>
                <h3 class="text-2xl sm:text-3xl font-bold text-white mb-4 leading-tight">
                  {feature.title}
                </h3>
                <p class="text-slate-400 text-base leading-relaxed mb-5">
                  {feature.description}
                </p>
                <ul class="space-y-2.5">
                  {feature.bullets.map((bullet) => (
                    <li class="flex items-start gap-2.5 text-slate-300 text-sm">
                      <span class="node-dot mt-1.5" style="width:5px;height:5px;box-shadow:none;"></span>
                      {bullet}
                    </li>
                  ))}
                </ul>
              </div>

              {/* Screenshot side */}
              <div class="flex-1 max-w-2xl w-full">
                <div class="relative group">
                  <div class={`absolute -inset-2 rounded-xl bg-[#22d3ee]/5 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500`}></div>
                  <div class="relative overflow-hidden rounded-xl border border-slate-800/60">
                    <img
                      src={feature.image}
                      alt={feature.imageAlt}
                      width="800"
                      height="500"
                      class="w-full h-auto"
                      loading="lazy"
                    />
                  </div>
                </div>
              </div>
            </div>

            {/* Network connector between features */}
            {!isLast && (
              <div class="flex justify-center py-8">
                <div class="flex flex-col items-center gap-0">
                  <div class="network-line-solid h-12"></div>
                  <span class="node-dot-ring"></span>
                  <div class="network-line-solid h-12"></div>
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>

    <!-- See all features -->
    <div class="mt-16 flex items-center gap-3">
      <div class="network-line-solid flex-1 max-w-[60px]"></div>
      <a href="/features" class="inline-flex items-center gap-2 text-[#22d3ee] hover:text-[#67e8f9] font-medium transition-colors">
        Explore all 100+ checks
        <ArrowRight class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>
