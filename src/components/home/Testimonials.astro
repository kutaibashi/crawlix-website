---
/**
 * Testimonials / Trust section.
 * Shows key differentiators as trust signals until real testimonials are available.
 */
import { Shield, DollarSign, Laptop, ArrowRight } from '@lucide/astro';

const differentiators = [
  {
    icon: Shield,
    title: 'Your data stays yours',
    description: 'Crawlix runs entirely on your machine. No data is uploaded to any server, ever. Your crawl results, client URLs, and audit data never leave your control.',
    stat: '0 bytes',
    statLabel: 'sent to the cloud',
  },
  {
    icon: DollarSign,
    title: 'No recurring fees',
    description: 'Buy once, own forever. No monthly subscriptions, no per-crawl charges, no surprise price hikes. The perpetual license includes all updates for the version you purchased.',
    stat: '$0/mo',
    statLabel: 'after purchase',
  },
  {
    icon: Laptop,
    title: 'Works everywhere',
    description: 'Native desktop app for Windows, macOS, and Linux. Works offline after installation. No browser extensions, no cloud dashboards, no account required.',
    stat: '3',
    statLabel: 'platforms supported',
  },
];
---

<section class="py-24 sm:py-32 relative overflow-hidden">
  <!-- Subtle background texture -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[900px] h-[600px] bg-cyan-500/5 rounded-full blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="inline-block text-sm font-semibold text-cyan-400 uppercase tracking-widest mb-4">
        Why Crawlix
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
        The SEO tool that respects<br />
        <span class="bg-gradient-to-r from-cyan-400 to-emerald-400 bg-clip-text text-transparent">your privacy and your wallet</span>
      </h2>
    </div>

    <!-- Differentiator Cards -->
    <div class="grid gap-8 lg:grid-cols-3">
      {differentiators.map(({ icon: Icon, title, description, stat, statLabel }) => (
        <div class="relative rounded-2xl border border-slate-800 bg-[#0a1d42]/60 p-8 hover:border-slate-700 transition-colors">
          {/* Stat callout */}
          <div class="mb-6">
            <span class="text-4xl font-black text-white">{stat}</span>
            <span class="block text-sm text-slate-500 mt-1">{statLabel}</span>
          </div>

          {/* Icon + Title */}
          <div class="flex items-center gap-3 mb-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-cyan-500/10 text-cyan-400">
              <Icon class="h-5 w-5" />
            </div>
            <h3 class="text-lg font-bold text-white">{title}</h3>
          </div>

          {/* Description */}
          <p class="text-slate-400 leading-relaxed">{description}</p>
        </div>
      ))}
    </div>

    <!-- Bottom link -->
    <div class="mt-16 text-center">
      <a href="/compare" class="inline-flex items-center gap-2 text-slate-400 hover:text-cyan-400 font-medium transition-colors">
        See how Crawlix compares to alternatives
        <ArrowRight class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>
