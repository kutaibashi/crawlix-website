---
/**
 * Why Crawlix — dramatic stats section.
 * Deep dark background, oversized numbers, no card wrappers.
 */
import { ArrowRight } from '@lucide/astro';

const differentiators = [
  {
    stat: '0',
    unit: 'bytes',
    label: 'sent to the cloud',
    description: 'Crawlix runs entirely on your machine. Your crawl results, client URLs, and audit data never leave your control. Ever.',
  },
  {
    stat: '$0',
    unit: '/mo',
    label: 'after purchase',
    description: 'Buy once, own forever. No monthly subscriptions, no per-crawl charges, no surprise price hikes.',
  },
  {
    stat: '2',
    unit: 'min',
    label: 'to first crawl',
    description: 'Download, install, paste a URL. No account creation, no onboarding wizard, no credit card.',
  },
];
---

<section class="py-24 sm:py-32 relative overflow-hidden" style="background:#040c1e;">
  <!-- Dot grid -->
  <div class="absolute inset-0 dot-grid opacity-40"></div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 relative">
    <!-- Section Header — centered (dramatic section) -->
    <div class="text-center mb-20">
      <span class="inline-flex items-center gap-2 text-sm font-semibold text-[#22d3ee] uppercase tracking-widest mb-4">
        <span class="node-dot" style="width:6px;height:6px;"></span>
        Why Crawlix
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
        The SEO tool that respects<br />
        <span class="bg-gradient-to-r from-[#22d3ee] to-[#67e8f9] bg-clip-text text-transparent">your privacy and your wallet</span>
      </h2>
    </div>

    <!-- Stats — no cards, just dramatic numbers -->
    <div class="grid gap-16 lg:grid-cols-3">
      {differentiators.map(({ stat, unit, label, description }) => (
        <div class="text-center lg:text-left">
          <div class="mb-4">
            <span class="text-6xl sm:text-7xl font-black text-white tracking-tight">{stat}</span>
            <span class="text-2xl sm:text-3xl font-bold text-[#22d3ee]">{unit}</span>
          </div>
          <div class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-3">{label}</div>
          <p class="text-slate-500 leading-relaxed text-sm">{description}</p>
        </div>
      ))}
    </div>

    <!-- Bottom link -->
    <div class="mt-16 flex items-center gap-3">
      <div class="network-line-solid flex-1 max-w-[60px]"></div>
      <a href="/compare" class="inline-flex items-center gap-2 text-slate-500 hover:text-[#22d3ee] font-medium transition-colors text-sm">
        See how Crawlix compares to alternatives
        <ArrowRight class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>
