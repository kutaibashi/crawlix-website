---
import { Download, ArrowRight } from '@lucide/astro';
import { getTotalSeoChecks } from '../../lib/keystatic';

const totalSeoChecks = await getTotalSeoChecks();

// Node clusters for left and right edges
const nodes: Array<{ x: number; y: number; size: number; opacity: number }> = [];
for (let i = 0; i < 24; i++) {
  const side = i < 12 ? 'left' : 'right';
  nodes.push({
    x: side === 'left' ? 2 + Math.random() * 16 : 82 + Math.random() * 16,
    y: 8 + Math.random() * 84,
    size: 1 + Math.random() * 2,
    opacity: 0.08 + Math.random() * 0.12,
  });
}
---

<section class="py-24 sm:py-32 relative overflow-hidden" style="background:#040c1e;">
  <!-- Node dots -->
  <div class="absolute inset-0 pointer-events-none">
    <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      {nodes.map(n => (
        <circle cx={`${n.x}%`} cy={`${n.y}%`} r={n.size * 0.13} fill="#22d3ee" opacity={n.opacity} />
      ))}
    </svg>
  </div>

  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 relative text-center">
    <!-- Badge -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-[#22d3ee]/8 border border-[#22d3ee]/15 px-4 py-2 text-sm text-[#22d3ee]">
      <span class="w-1.5 h-1.5 rounded-full bg-[#22d3ee]"></span>
      Now available for Windows & Linux
    </div>

    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
      Ready to Audit Your Site?
    </h2>

    <p class="mx-auto mt-5 max-w-xl text-lg text-slate-300 leading-relaxed">
      Download Crawlix and run {totalSeoChecks}+ SEO checks in minutes.
    </p>
    <p class="mt-2 font-semibold text-white">
      Your data stays on your machine. Always.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/download" class="group inline-flex items-center gap-2 rounded-xl bg-[#22d3ee] px-8 py-4 font-semibold text-slate-900 hover:bg-[#67e8f9] transition-all shadow-lg shadow-[#22d3ee]/20 hover:shadow-[#22d3ee]/30">
        <Download class="h-5 w-5" />
        Download for Free
        <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
      </a>
      <a href="/pricing" class="inline-flex items-center gap-2 rounded-xl border border-slate-700 bg-slate-800/50 px-8 py-4 font-semibold text-white hover:bg-slate-700/50 transition-colors">
        View Pricing
      </a>
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-5 text-xs text-slate-500">
      {['No signup required', 'Works offline', 'GDPR compliant'].map(item => (
        <span class="flex items-center gap-1.5">
          <span class="w-1 h-1 rounded-full bg-emerald-500/50"></span>
          {item}
        </span>
      ))}
    </div>
  </div>
</section>
