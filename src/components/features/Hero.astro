---
import { Download, ChevronDown } from '@lucide/astro';
import Button from '../ui/Button.astro';
import { getTotalSeoChecks } from '../../lib/keystatic';

const totalSeoChecks = await getTotalSeoChecks();
---

<section class="relative pt-32 pb-20 overflow-hidden" style="background:radial-gradient(ellipse 60% 50% at 50% 40%, #0c2340, #040c1e);">
  <!-- Dot grid background -->
  <div class="absolute inset-0 dot-grid opacity-30"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-2xl mx-auto animate-on-scroll">
      <!-- Stats badge -->
      <div class="inline-flex items-center gap-2 rounded-full border border-[#22d3ee]/15 bg-[#22d3ee]/5 px-4 py-1.5 text-xs text-[#22d3ee]/90 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-[#22d3ee] shadow-[0_0_8px_rgba(34,211,238,0.4)]"></span>
        <span class="font-semibold">11 Categories</span>
        <span class="text-slate-600">|</span>
        <span class="text-slate-500">{totalSeoChecks}+ Checks</span>
      </div>

      <!-- Headline -->
      <h1 class="text-3xl font-bold tracking-tight sm:text-5xl lg:text-6xl leading-[1.1]">
        <span class="text-white">Every Check Your Site Needs.</span><br />
        <span class="gradient-text-cyan">Nothing You Don't.</span>
      </h1>

      <!-- Subtitle -->
      <p class="mt-6 text-base sm:text-lg text-slate-400 leading-relaxed max-w-xl mx-auto">
        Technical SEO, content quality, Core Web Vitals, accessibility, AI search readiness — audited locally on your machine. No cloud. No limits.
      </p>

      <!-- CTAs -->
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/download" class="group inline-flex items-center gap-2 rounded-xl bg-[#22d3ee] px-7 py-3.5 text-base font-semibold text-slate-900 hover:bg-[#67e8f9] transition-all hero-cta-glow">
          <Download class="h-5 w-5" />
          Download Free
        </a>
        <Button href="#categories" variant="ghost" size="lg">
          Explore All Checks
          <ChevronDown class="h-5 w-5" />
        </Button>
      </div>

      <!-- Trust line -->
      <div class="mt-6 flex flex-wrap gap-x-5 gap-y-1.5 justify-center text-xs text-slate-500">
        {['Free tier included', 'Windows & Linux', 'No account needed'].map(item => (
          <span class="flex items-center gap-1.5">
            <span class="w-1 h-1 rounded-full bg-emerald-500/70"></span>
            {item}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-cta-glow {
    box-shadow: 0 0 24px rgba(34, 211, 238, 0.2), 0 0 48px rgba(34, 211, 238, 0.06);
    transition: box-shadow 0.3s ease;
  }
  .hero-cta-glow:hover {
    box-shadow: 0 0 36px rgba(34, 211, 238, 0.35), 0 0 72px rgba(34, 211, 238, 0.12);
  }
</style>
