---
import { Check } from '@lucide/astro';
import { exportFormats, integrations } from '../../data/features';

const desktopFeatures = [
  { title: '100% Local', description: 'Data stored in SQLite on your machine' },
  { title: 'Works Offline', description: 'No internet required after install' },
  { title: 'Pause & Resume', description: 'Checkpoint/resume for large crawls' },
  { title: 'Auto-Updates', description: 'Always on the latest version' },
];

const formatColors: Record<string, { bg: string; text: string }> = {
  PDF: { bg: 'rgba(239,68,68,0.1)', text: '#f87171' },
  CSV: { bg: 'rgba(34,197,94,0.1)', text: '#4ade80' },
  JSON: { bg: 'rgba(99,102,241,0.1)', text: '#818cf8' },
  Excel: { bg: 'rgba(16,185,129,0.1)', text: '#34d399' },
  HTML: { bg: 'rgba(34,211,238,0.1)', text: '#22d3ee' },
};
---

<section class="py-24 sm:py-32 relative overflow-hidden" style="background:#091a3d;">
  <div class="absolute inset-0 dot-grid opacity-20"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative">
    <!-- Section header -->
    <div class="section-header-bar mb-12 max-w-lg animate-on-scroll">
      <span class="text-sm font-semibold text-[#22d3ee] uppercase tracking-widest">Beyond the Checks</span>
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl mt-2">
        Export, integrate, own your data
      </h2>
    </div>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3 stagger-children">
      <!-- Column 1: Export Formats -->
      <div class="rounded-2xl p-6" style="background:rgba(14,38,85,0.3);border:1px solid rgba(30,41,59,0.6);">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="w-8 h-8 rounded-lg bg-[#22d3ee]/10 flex items-center justify-center">
            <span class="text-[#22d3ee] text-sm">&#128196;</span>
          </div>
          <h3 class="text-sm font-bold text-white">5 Export Formats</h3>
        </div>
        <div class="flex flex-col gap-3">
          {exportFormats.map(format => {
            const colors = formatColors[format.name] || formatColors.HTML;
            return (
              <div class="flex items-center gap-3">
                <div class="w-7 h-7 rounded-md flex items-center justify-center flex-shrink-0" style={`background:${colors.bg};`}>
                  <span class="text-[10px] font-bold" style={`color:${colors.text};`}>{format.name === 'Excel' ? 'XLS' : format.name === 'HTML' ? '</>' : format.name}</span>
                </div>
                <div>
                  <div class="text-xs font-semibold text-white">{format.name}</div>
                  <div class="text-[9px] text-slate-500">{format.description}</div>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Column 2: Integrations -->
      <div class="rounded-2xl p-6" style="background:rgba(14,38,85,0.3);border:1px solid rgba(30,41,59,0.6);">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center">
            <span class="text-emerald-400 text-sm">&#128268;</span>
          </div>
          <h3 class="text-sm font-bold text-white">Integrations</h3>
        </div>
        <div class="flex flex-col gap-4">
          {integrations.map((integration, i) => (
            <div>
              <div class="text-xs font-semibold text-white">{integration.name}</div>
              <div class="text-[10px] text-slate-500 mt-0.5">{integration.description}</div>
              {i < integrations.length - 1 && <div class="mt-4 h-px" style="background:rgba(30,41,59,0.8);"></div>}
            </div>
          ))}
        </div>
        <div class="mt-4">
          <span class="text-[9px] text-slate-500 bg-slate-800/50 px-2 py-1 rounded">Pro & Agency tiers</span>
        </div>
      </div>

      <!-- Column 3: Desktop App (full-width on tablet) -->
      <div class="rounded-2xl p-6 md:col-span-2 lg:col-span-1" style="background:rgba(14,38,85,0.3);border:1px solid rgba(30,41,59,0.6);">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="w-8 h-8 rounded-lg bg-[#22d3ee]/10 flex items-center justify-center">
            <span class="text-[#22d3ee] text-sm">&#128187;</span>
          </div>
          <h3 class="text-sm font-bold text-white">Desktop App</h3>
        </div>
        <div class="flex flex-col gap-3">
          {desktopFeatures.map(feature => (
            <div class="flex items-start gap-2.5">
              <Check class="h-3.5 w-3.5 text-emerald-400 mt-0.5 flex-shrink-0" />
              <div>
                <div class="text-xs font-semibold text-white">{feature.title}</div>
                <div class="text-[9px] text-slate-500">{feature.description}</div>
              </div>
            </div>
          ))}
        </div>
        <div class="flex gap-2 mt-5">
          <span class="text-[9px] text-slate-400 bg-slate-800/50 px-2 py-1 rounded">Windows</span>
          <span class="text-[9px] text-slate-400 bg-slate-800/50 px-2 py-1 rounded">Linux</span>
          <span class="text-[9px] text-slate-500 bg-slate-800/30 px-2 py-1 rounded">macOS soon</span>
        </div>
      </div>
    </div>
  </div>
</section>
