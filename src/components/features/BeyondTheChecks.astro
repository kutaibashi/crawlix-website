---
import { Check, FileText, Table, Braces, FileSpreadsheet, Globe, BarChart3, Search, Zap, Monitor, Shield, Wifi, RefreshCw } from '@lucide/astro';
import { exportFormats, integrations } from '../../data/features';

const desktopFeatures = [
  { title: '100% Local', description: 'Data stored in SQLite on your machine', icon: 'Shield' },
  { title: 'Works Offline', description: 'No internet required after install', icon: 'Wifi' },
  { title: 'Pause & Resume', description: 'Checkpoint/resume for large crawls', icon: 'RefreshCw' },
  { title: 'Auto-Updates', description: 'Always on the latest version', icon: 'Monitor' },
];

const formatColors: Record<string, { bg: string; text: string; border: string }> = {
  PDF: { bg: 'rgba(239,68,68,0.08)', text: '#f87171', border: 'rgba(239,68,68,0.15)' },
  CSV: { bg: 'rgba(34,197,94,0.08)', text: '#4ade80', border: 'rgba(34,197,94,0.15)' },
  JSON: { bg: 'rgba(99,102,241,0.08)', text: '#818cf8', border: 'rgba(99,102,241,0.15)' },
  Excel: { bg: 'rgba(16,185,129,0.08)', text: '#34d399', border: 'rgba(16,185,129,0.15)' },
  HTML: { bg: 'rgba(34,211,238,0.08)', text: '#22d3ee', border: 'rgba(34,211,238,0.15)' },
};

// Generate node network for background
const nodes: Array<{ x: number; y: number; size: number; opacity: number }> = [];
const seed = 42;
function rand(i: number) {
  const x = Math.sin(seed + i * 127.1) * 43758.5453;
  return x - Math.floor(x);
}
for (let i = 0; i < 40; i++) {
  nodes.push({
    x: rand(i * 3) * 100,
    y: rand(i * 3 + 1) * 100,
    size: 0.15 + rand(i * 3 + 2) * 0.2,
    opacity: 0.06 + rand(i * 7) * 0.12,
  });
}
const edges: Array<{ x1: number; y1: number; x2: number; y2: number; opacity: number }> = [];
for (let i = 0; i < nodes.length; i++) {
  for (let j = i + 1; j < nodes.length; j++) {
    const dx = nodes[i].x - nodes[j].x;
    const dy = nodes[i].y - nodes[j].y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < 18 && rand(i * 100 + j) > 0.45) {
      edges.push({
        x1: nodes[i].x, y1: nodes[i].y,
        x2: nodes[j].x, y2: nodes[j].y,
        opacity: 0.03 + rand(i * 50 + j) * 0.05,
      });
    }
  }
}

const integrationIcons: Record<string, any> = { BarChart3, Search, Zap };
---

<section class="py-24 sm:py-32 relative overflow-hidden" style="background:#091a3d;">
  <!-- Node network background -->
  <div class="absolute inset-0 pointer-events-none">
    <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      {edges.map(e => (
        <line x1={`${e.x1}`} y1={`${e.y1}`} x2={`${e.x2}`} y2={`${e.y2}`}
          stroke="#22d3ee" stroke-width="0.06" opacity={e.opacity} />
      ))}
      {nodes.map(n => (
        <circle cx={`${n.x}`} cy={`${n.y}`} r={n.size} fill="#22d3ee" opacity={n.opacity} />
      ))}
    </svg>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Section header -->
    <div class="section-header-bar mb-14 max-w-xl animate-on-scroll">
      <span class="text-sm font-semibold text-[#22d3ee] uppercase tracking-widest">Beyond the Checks</span>
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl mt-3">
        Export, integrate, own your data
      </h2>
      <p class="text-slate-400 text-base mt-3">Get your audit data out in any format. Connect your tools. Keep everything local.</p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 stagger-children">

      <!-- Column 1: Export Formats -->
      <div class="beyond-card rounded-2xl p-8" style="background:rgba(14,38,85,0.45);border:1px solid rgba(34,211,238,0.1);backdrop-filter:blur(8px);">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-[#22d3ee]/10 flex items-center justify-center border border-[#22d3ee]/15">
            <FileText class="h-5 w-5 text-[#22d3ee]" />
          </div>
          <h3 class="text-lg font-bold text-white">5 Export Formats</h3>
        </div>
        <div class="flex flex-col gap-4">
          {exportFormats.map(format => {
            const colors = formatColors[format.name] || formatColors.HTML;
            return (
              <div class="flex items-center gap-4 group">
                <div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0 transition-transform group-hover:scale-105"
                     style={`background:${colors.bg};border:1px solid ${colors.border};`}>
                  <span class="text-sm font-bold" style={`color:${colors.text};`}>
                    {format.name === 'Excel' ? 'XLS' : format.name === 'HTML' ? '</>' : format.name}
                  </span>
                </div>
                <div>
                  <div class="text-base font-semibold text-white">{format.name}</div>
                  <div class="text-sm text-slate-400">{format.description}</div>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Column 2: Integrations -->
      <div class="beyond-card rounded-2xl p-8" style="background:rgba(14,38,85,0.45);border:1px solid rgba(16,185,129,0.1);backdrop-filter:blur(8px);">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center border border-emerald-500/15">
            <BarChart3 class="h-5 w-5 text-emerald-400" />
          </div>
          <h3 class="text-lg font-bold text-white">Integrations</h3>
        </div>
        <div class="flex flex-col gap-5">
          {integrations.map((integration, i) => {
            const IconComp = integrationIcons[integration.icon as string] || Search;
            return (
              <div class="group">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-emerald-500/8 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <IconComp class="h-4 w-4 text-emerald-400" />
                  </div>
                  <div>
                    <div class="text-base font-semibold text-white">{integration.name}</div>
                    <div class="text-sm text-slate-400 mt-0.5">{integration.description}</div>
                  </div>
                </div>
                {i < integrations.length - 1 && (
                  <div class="mt-5 flex items-center gap-3">
                    <div class="h-px flex-1" style="background:linear-gradient(to right, rgba(16,185,129,0.15), transparent);"></div>
                  </div>
                )}
              </div>
            );
          })}
        </div>
        <div class="mt-6">
          <span class="text-xs font-medium text-emerald-400/70 bg-emerald-500/8 border border-emerald-500/12 py-1.5 px-3 rounded-full">Pro & Agency tiers</span>
        </div>
      </div>

      <!-- Column 3: Desktop App -->
      <div class="beyond-card rounded-2xl p-8 md:col-span-2 lg:col-span-1" style="background:rgba(14,38,85,0.45);border:1px solid rgba(34,211,238,0.1);backdrop-filter:blur(8px);">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-[#22d3ee]/10 flex items-center justify-center border border-[#22d3ee]/15">
            <Monitor class="h-5 w-5 text-[#22d3ee]" />
          </div>
          <h3 class="text-lg font-bold text-white">Desktop App</h3>
        </div>
        <div class="flex flex-col gap-4">
          {desktopFeatures.map(feature => (
            <div class="flex items-start gap-3.5 group">
              <div class="w-8 h-8 rounded-lg bg-emerald-500/8 flex items-center justify-center flex-shrink-0 mt-0.5">
                <Check class="h-4 w-4 text-emerald-400" />
              </div>
              <div>
                <div class="text-base font-semibold text-white">{feature.title}</div>
                <div class="text-sm text-slate-400">{feature.description}</div>
              </div>
            </div>
          ))}
        </div>
        <div class="flex gap-2.5 mt-6">
          <span class="text-sm font-medium text-slate-300 bg-slate-700/40 border border-slate-600/30 py-2 px-4 rounded-lg">Windows</span>
          <span class="text-sm font-medium text-slate-300 bg-slate-700/40 border border-slate-600/30 py-2 px-4 rounded-lg">Linux</span>
          <span class="text-sm font-medium text-slate-500 bg-slate-800/40 border border-slate-700/20 py-2 px-4 rounded-lg">macOS soon</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .beyond-card {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.3s ease,
                box-shadow 0.3s ease;
  }
  .beyond-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 30px rgba(34,211,238,0.06), 0 12px 32px rgba(0,0,0,0.25);
    border-color: rgba(34,211,238,0.2) !important;
  }
</style>
